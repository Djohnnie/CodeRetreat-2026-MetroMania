@page "/not-found"
@layout MainLayout
@inject IStringLocalizer<Localization> Loc

<PageTitle>MetroMania - @Loc["PageNotFound"]</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-8 text-center">
    <MudIcon Icon="@Icons.Material.Filled.SearchOff" Size="Size.Large" Color="Color.Secondary" />
    <MudText Typo="Typo.h4" Class="mt-4">@Loc["PageNotFound"]</MudText>
    <MudText Typo="Typo.body1" Class="mt-2 mb-4">@Loc["NotFoundMessage"]</MudText>
    <MudButton Href="/" Variant="Variant.Filled" Color="Color.Primary">@Loc["BackToDashboard"]</MudButton>
</MudContainer>