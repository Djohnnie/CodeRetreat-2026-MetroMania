@page "/play/renders"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using MetroMania.Application.DTOs
@using MetroMania.Application.Submissions.Queries
@using MetroMania.Web.Services
@implements IAsyncDisposable
@inject MetroManiaApiClient ApiClient
@inject IStringLocalizer<Localization> Loc
@inject NavigationManager Navigation

<PageTitle>MetroMania - @Loc["Replay"]</PageTitle>

<div class="d-flex align-center mb-1">
    <MudIconButton Icon="@Icons.Material.Filled.ArrowBack"
                   Size="Size.Small"
                   OnClick="@(() => Navigation.NavigateTo("/play"))"
                   Class="mr-1" />
    <MudIcon Icon="@Icons.Material.Filled.Slideshow" Class="mr-2" Color="Color.Primary" />
    <MudText Typo="Typo.h4" Style="font-weight: 700;">@Loc["Replay"]</MudText>
</div>
<MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-6">@Loc["ReplaysSubtitle"]</MudText>

@* Level navigation bar *@
@if (_renderLevels.Count > 1)
{
    <MudPaper Elevation="0" Class="mb-3 pa-2"
              Style="border: 1px solid var(--mud-palette-lines-default); border-radius: 12px; display: grid; grid-template-columns: 1fr auto 1fr; align-items: center;">

        <div style="display: flex; justify-content: flex-start;">
            <MudTooltip Text="@PrevLevelLabel">
                <MudButton StartIcon="@Icons.Material.Filled.ArrowBackIos"
                           Variant="Variant.Text"
                           Color="Color.Primary"
                           OnClick="NavigateToPreviousLevel">
                    @PrevLevelTitle
                </MudButton>
            </MudTooltip>
        </div>

        <div style="text-align: center; padding: 0 12px; white-space: nowrap;">
            <MudText Typo="Typo.body2" Color="Color.Secondary">
                @(_currentLevelIndex + 1) / @_renderLevels.Count
            </MudText>
            <MudText Typo="Typo.subtitle2" Style="font-weight: 700;">
                @CurrentLevelTitle
            </MudText>
        </div>

        <div style="display: flex; justify-content: flex-end;">
            <MudTooltip Text="@NextLevelLabel">
                <MudButton EndIcon="@Icons.Material.Filled.ArrowForwardIos"
                           Variant="Variant.Text"
                           Color="Color.Primary"
                           OnClick="NavigateToNextLevel">
                    @NextLevelTitle
                </MudButton>
            </MudTooltip>
        </div>

    </MudPaper>
}

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mb-4" />
}
else if (_totalFrames == 0)
{
    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">
        @Loc["NoRendersAvailable"]
    </MudAlert>
}
else
{
    <div @ref="_containerRef" tabindex="0" @onkeydown="HandleKeyDown"
         style="outline: none; display: flex; flex-direction: column; align-items: center; gap: 16px;">

        @* Hour counter and controls *@
        <MudPaper Elevation="0" Class="pa-3"
                  Style="border: 1px solid var(--mud-palette-lines-default); border-radius: 12px; width: 100%; display: flex; flex-wrap: wrap; align-items: center;">

            @* Left: navigation controls *@
            <div style="display: flex; align-items: center; gap: 4px; flex: 1;">
                <MudTooltip Text="@Loc["PreviousDay"]">
                    <MudIconButton Icon="@Icons.Material.Filled.ChevronLeft"
                                   Color="Color.Primary"
                                   Disabled="_currentHour <= 1"
                                   OnClick="Previous" />
                </MudTooltip>

                @if (_isPlaying)
                {
                    <MudTooltip Text="@Loc["StopPlayback"]">
                        <MudIconButton Icon="@Icons.Material.Filled.Stop"
                                       Color="Color.Error"
                                       OnClick="StopPlayback" />
                    </MudTooltip>
                }
                else
                {
                    <MudTooltip Text="@Loc["Play"]">
                        <MudIconButton Icon="@Icons.Material.Filled.PlayArrow"
                                       Color="Color.Success"
                                       Disabled="_currentHour >= _totalFrames"
                                       OnClick="StartPlayback" />
                    </MudTooltip>
                }

                <MudTooltip Text="@Loc["NextDay"]">
                    <MudIconButton Icon="@Icons.Material.Filled.ChevronRight"
                                   Color="Color.Primary"
                                   Disabled="_currentHour >= _totalFrames"
                                   OnClick="Next" />
                </MudTooltip>
            </div>

            @* Center: day/hour label *@
            <div style="flex: none; text-align: center; white-space: nowrap;">
                <MudText Typo="Typo.h6" Style="font-weight: 700; letter-spacing: 0.03em;">
                    @DayHourLabel
                </MudText>
            </div>

            @* Right: editable hour counter + progress *@
            <div style="display: flex; align-items: center; gap: 12px; flex: 1; justify-content: flex-end;">
                <MudTooltip Text="@Loc["DownloadZip"]">
                    <MudIconButton Icon="@Icons.Material.Filled.FolderZip"
                                   Color="Color.Secondary"
                                   Href="@($"/api/downloads/submissions/{SubmissionId}/levels/{LevelId}/zip")"
                                   Target="_blank" />
                </MudTooltip>

                <span style="font-weight: 600; white-space: nowrap; display: flex; align-items: center; gap: 4px;">
                    @Loc["Hour"]
                    <input type="text"
                           inputmode="numeric"
                           value="@_hourInputStr"
                           @oninput="@(e => _hourInputStr = e.Value?.ToString() ?? string.Empty)"
                           @onkeydown="HandleHourInputKeyDown"
                           @onkeydown:stopPropagation="true"
                           @onblur="@(() => { if (int.TryParse(_hourInputStr, out var h)) JumpToHour(h); })"
                           style="width: 56px; text-align: center; background: transparent; border: none; border-bottom: 1px solid var(--mud-palette-text-primary); color: var(--mud-palette-text-primary); font-size: 1rem; font-weight: 600; font-family: inherit; outline: none;" />
                    <MudText Typo="Typo.caption" Color="Color.Secondary" Style="display: inline;">
                        / @_totalFrames
                    </MudText>
                </span>

                <MudProgressLinear Value="@((double)_currentHour / _totalFrames * 100)"
                                   Color="Color.Primary" Rounded="true"
                                   Style="width: 100px;" />
            </div>

            @* Slider *@
            <div style="width: 100%; margin-top: 4px;">
                <MudSlider T="int" Value="_currentHour" ValueChanged="OnSliderChanged"
                           Min="1" Max="_totalFrames" Step="1"
                           Color="Color.Primary" />
            </div>
        </MudPaper>

        @* SVG frame — loaded directly from server endpoint *@
        <MudPaper Elevation="2" Class="pa-2"
                  Style="border-radius: 12px; overflow: auto;">
            <div style="display: inline-block;">
                <img src="@FrameUrl" alt="@($"Frame {_currentHour}")" />
            </div>
        </MudPaper>

    </div>
}

@code {
    [Parameter, SupplyParameterFromQuery(Name = "submissionId")] public Guid SubmissionId { get; set; }
    [Parameter, SupplyParameterFromQuery(Name = "levelId")] public Guid LevelId { get; set; }

    private int _totalFrames;
    private int _currentHour = 1;
    private string _hourInputStr = "1";
    private bool _loading = true;
    private bool _isPlaying;
    private CancellationTokenSource? _playCts;
    private ElementReference _containerRef;

    private List<SubmissionRenderLevelDto> _renderLevels = [];
    private Guid _loadedLevelId;

    private int _currentLevelIndex => _renderLevels.FindIndex(l => l.LevelId == LevelId);

    private string CurrentLevelTitle =>
        _currentLevelIndex >= 0 ? _renderLevels[_currentLevelIndex].GetLocalizedTitle() : string.Empty;

    private string PrevLevelTitle
    {
        get
        {
            if (_renderLevels.Count == 0) return string.Empty;
            var idx = (_currentLevelIndex - 1 + _renderLevels.Count) % _renderLevels.Count;
            return _renderLevels[idx].GetLocalizedTitle();
        }
    }

    private string NextLevelTitle
    {
        get
        {
            if (_renderLevels.Count == 0) return string.Empty;
            var idx = (_currentLevelIndex + 1) % _renderLevels.Count;
            return _renderLevels[idx].GetLocalizedTitle();
        }
    }

    private string PrevLevelLabel => Loc["PreviousLevel"].ToString();
    private string NextLevelLabel => Loc["NextLevel"].ToString();

    private string FrameUrl => $"/api/renders/{SubmissionId}/{LevelId}/{_currentHour}.svg";

    protected override async Task OnInitializedAsync()
    {
        _renderLevels = await ApiClient.GetSubmissionRenderLevelsAsync(SubmissionId);
        await LoadFrameDataAsync();
    }

    protected override async Task OnParametersSetAsync()
    {
        if (_loadedLevelId != LevelId && _loadedLevelId != default)
            await LoadFrameDataAsync();
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender && _totalFrames > 0)
            await _containerRef.FocusAsync();
    }

    private async Task LoadFrameDataAsync()
    {
        StopPlayback();
        _loading = true;
        _currentHour = 1;
        _hourInputStr = "1";
        _loadedLevelId = LevelId;
        var info = await ApiClient.GetSubmissionRenderInfoAsync(SubmissionId, LevelId);
        _totalFrames = info?.TotalFrames ?? 0;
        _loading = false;
    }

    private void NavigateToPreviousLevel()
    {
        if (_renderLevels.Count == 0) return;
        var idx = (_currentLevelIndex - 1 + _renderLevels.Count) % _renderLevels.Count;
        Navigation.NavigateTo($"/play/renders?submissionId={SubmissionId}&levelId={_renderLevels[idx].LevelId}");
    }

    private void NavigateToNextLevel()
    {
        if (_renderLevels.Count == 0) return;
        var idx = (_currentLevelIndex + 1) % _renderLevels.Count;
        Navigation.NavigateTo($"/play/renders?submissionId={SubmissionId}&levelId={_renderLevels[idx].LevelId}");
    }

    private void HandleKeyDown(KeyboardEventArgs e)
    {
        switch (e.Key)
        {
            case "ArrowLeft":
                Previous();
                break;
            case "ArrowRight":
                Next();
                break;
        }
    }

    private void HandleHourInputKeyDown(KeyboardEventArgs e)
    {
        switch (e.Key)
        {
            case "ArrowUp":
                Next();
                break;
            case "ArrowDown":
                Previous();
                break;
            case "Enter":
                if (int.TryParse(_hourInputStr, out var h))
                    JumpToHour(h);
                break;
        }
    }

    private string DayHourLabel
    {
        get
        {
            if (_totalFrames == 0) return string.Empty;
            int absoluteHour = Math.Max(0, _currentHour - 1);
            int day = absoluteHour / 24 + 1;
            int hourOfDay = absoluteHour % 24;
            string dowKey = ((DayOfWeek)((absoluteHour / 24 + 1) % 7)) switch
            {
                DayOfWeek.Monday    => "DayMo",
                DayOfWeek.Tuesday   => "DayTu",
                DayOfWeek.Wednesday => "DayWe",
                DayOfWeek.Thursday  => "DayTh",
                DayOfWeek.Friday    => "DayFr",
                DayOfWeek.Saturday  => "DaySa",
                DayOfWeek.Sunday    => "DaySu",
                _                   => "DayMo"
            };
            return $"{Loc[dowKey]} {day} / {hourOfDay:D2}:00";
        }
    }

    private void SetCurrentHour(int hour)
    {
        _currentHour = Math.Clamp(hour, 1, _totalFrames);
        _hourInputStr = _currentHour.ToString();
    }

    private void JumpToHour(int hour) => SetCurrentHour(hour);

    private void OnSliderChanged(int value) => SetCurrentHour(value);

    private void Previous()
    {
        if (_currentHour > 1)
            SetCurrentHour(_currentHour - 1);
    }

    private void Next()
    {
        if (_currentHour < _totalFrames)
            SetCurrentHour(_currentHour + 1);
    }

    private void StartPlayback()
    {
        if (_isPlaying) return;
        _playCts = new CancellationTokenSource();
        _isPlaying = true;
        _ = RunPlaybackAsync(_playCts.Token);
    }

    private void StopPlayback()
    {
        _playCts?.Cancel();
        _isPlaying = false;
    }

    private async Task RunPlaybackAsync(CancellationToken ct)
    {
        try
        {
            while (!ct.IsCancellationRequested && _currentHour < _totalFrames)
            {
                await Task.Delay(250, ct);
                SetCurrentHour(_currentHour + 1);
                await InvokeAsync(StateHasChanged);
            }
        }
        catch (OperationCanceledException) { }
        finally
        {
            _isPlaying = false;
            await InvokeAsync(StateHasChanged);
        }
    }

    public ValueTask DisposeAsync()
    {
        _playCts?.Cancel();
        _playCts?.Dispose();
        return ValueTask.CompletedTask;
    }
}
