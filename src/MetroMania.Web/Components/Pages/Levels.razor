@page "/admin/levels"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Admin")]
@using MetroMania.Application.DTOs
@using MetroMania.Domain.Entities
@using MetroMania.Web.Services
@inject MetroManiaApiClient ApiClient
@inject NavigationManager Navigation
@inject IStringLocalizer<Localization> Loc

<PageTitle>MetroMania - @Loc["Levels"]</PageTitle>

<div class="d-flex align-center mb-1">
    <MudIcon Icon="@Icons.Material.Filled.Layers" Class="mr-2" Color="Color.Primary" />
    <MudText Typo="Typo.h4" Style="font-weight: 700;">@Loc["Levels"]</MudText>
</div>
<MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-6">@Loc["LevelEditorSubtitle"]</MudText>

@if (!string.IsNullOrEmpty(_message))
{
    <MudAlert Severity="_messageSeverity" Class="mb-4" Variant="Variant.Outlined" Dense="true"
              ShowCloseIcon="true" CloseIconClicked="() => _message = null">@_message</MudAlert>
}

<MudButton Variant="Variant.Filled" Color="Color.Primary" StartIcon="@Icons.Material.Filled.Add"
           OnClick="StartCreate" Class="mb-4" Style="text-transform: none; font-weight: 600;"
           Disabled="_editing">
    @Loc["AddLevel"]
</MudButton>

@if (_editing)
{
    <MudPaper Class="pa-5 mb-4" Elevation="0" Style="border: 1px solid var(--mud-palette-lines-default);">
        <MudText Typo="Typo.h6" Class="mb-3" Style="font-weight: 600;">
            @(_editId is null ? Loc["AddLevel"] : Loc["EditLevel"])
        </MudText>

        <!-- English -->
        <MudText Typo="Typo.subtitle2" Class="mb-2" Style="font-weight: 600;">🇬🇧 @Loc["English"]</MudText>
        <MudTextField @bind-Value="_editTitleEn" Label="@Loc["TitleEN"]" Variant="Variant.Outlined"
                      Required="true" RequiredError="@Loc["TitleRequired"]" Class="mb-3"
                      Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Title" />
        <MudTextField @bind-Value="_editDescriptionEn" Label="@Loc["DescriptionEN"]" Variant="Variant.Outlined"
                      Lines="2" Class="mb-4"
                      Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Description" />

        <!-- Dutch -->
        <MudText Typo="Typo.subtitle2" Class="mb-2" Style="font-weight: 600;">🇳🇱 @Loc["Dutch"]</MudText>
        <MudTextField @bind-Value="_editTitleNl" Label="@Loc["TitleNL"]" Variant="Variant.Outlined" Class="mb-3"
                      Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Title" />
        <MudTextField @bind-Value="_editDescriptionNl" Label="@Loc["DescriptionNL"]" Variant="Variant.Outlined"
                      Lines="2" Class="mb-4"
                      Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Description" />
        <div class="d-flex gap-3 mb-4">
            <MudNumericField @bind-Value="_editGridWidth" Label="@Loc["GridWidth"]" Variant="Variant.Outlined"
                             Min="3" Max="30" Style="max-width: 150px;"
                             Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.SwapHoriz" />
            <MudText Typo="Typo.h6" Class="align-self-center" Style="font-weight: 300;">x</MudText>
            <MudNumericField @bind-Value="_editGridHeight" Label="@Loc["GridHeight"]" Variant="Variant.Outlined"
                             Min="3" Max="30" Style="max-width: 150px;"
                             Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.SwapVert" />
        </div>
        <div class="d-flex gap-2">
            <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="SaveLevel"
                       Disabled="_saving || string.IsNullOrWhiteSpace(_editTitleEn)"
                       Style="text-transform: none; font-weight: 600;">
                @if (_saving)
                {
                    <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" />
                }
                @Loc["SaveLevel"]
            </MudButton>
            <MudButton Variant="Variant.Text" Color="Color.Default" OnClick="CancelEdit"
                       Style="text-transform: none;">
                @Loc["Cancel"]
            </MudButton>
        </div>
    </MudPaper>
}

@if (_levels is null)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_levels.Count == 0)
{
    <MudPaper Class="pa-8 text-center" Elevation="0" Style="border: 1px solid var(--mud-palette-lines-default);">
        <MudIcon Icon="@Icons.Material.Filled.Layers" Style="font-size: 3rem;" Color="Color.Secondary" />
        <MudText Typo="Typo.body1" Color="Color.Secondary" Class="mt-3">@Loc["NoLevelsYet"]</MudText>
    </MudPaper>
}
else
{
    <MudPaper Elevation="0" Style="border: 1px solid var(--mud-palette-lines-default); overflow: hidden;">
        <MudTable Items="_levels" Hover="true" Elevation="0" Dense="true" Breakpoint="Breakpoint.Sm">
            <HeaderContent>
                <MudTh Style="width: 60px;">@Loc["Order"]</MudTh>
                <MudTh>@Loc["LevelTitle"]</MudTh>
                <MudTh>@Loc["GridSize"]</MudTh>
                <MudTh>@Loc["LevelDescription"]</MudTh>
                <MudTh Style="text-align: right;">@Loc["Actions"]</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="@Loc["Order"]">
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Default">
                        @(context.SortOrder + 1)
                    </MudChip>
                </MudTd>
                <MudTd DataLabel="@Loc["LevelTitle"]">
                    <MudText Style="font-weight: 600;">@context.GetLocalizedTitle()</MudText>
                </MudTd>
                <MudTd DataLabel="@Loc["GridSize"]">
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Info">
                        @context.GridWidth x @context.GridHeight
                    </MudChip>
                </MudTd>
                <MudTd DataLabel="@Loc["LevelDescription"]">
                    <MudText Typo="Typo.body2" Color="Color.Secondary" Style="max-width: 300px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                        @context.GetLocalizedDescription()
                    </MudText>
                </MudTd>
                <MudTd DataLabel="@Loc["Actions"]" Style="text-align: right; white-space: nowrap;">
                    <MudTooltip Text="@Loc["EditGrid"]">
                        <MudIconButton Icon="@Icons.Material.Filled.GridOn" Color="Color.Primary" Size="Size.Small"
                                       Disabled="_editing"
                                       OnClick="@(() => Navigation.NavigateTo($"/admin/levels/{context.Id}"))" />
                    </MudTooltip>
                    <MudTooltip Text="@Loc["MoveUp"]">
                        <MudIconButton Icon="@Icons.Material.Filled.ArrowUpward" Size="Size.Small"
                                       Disabled="@(context.SortOrder == 0 || _editing)"
                                       OnClick="() => MoveLevel(context.Id, -1)" />
                    </MudTooltip>
                    <MudTooltip Text="@Loc["MoveDown"]">
                        <MudIconButton Icon="@Icons.Material.Filled.ArrowDownward" Size="Size.Small"
                                       Disabled="@(context.SortOrder == _levels!.Count - 1 || _editing)"
                                       OnClick="() => MoveLevel(context.Id, 1)" />
                    </MudTooltip>
                    <MudTooltip Text="@Loc["Edit"]">
                        <MudIconButton Icon="@Icons.Material.Filled.Edit" Color="Color.Primary" Size="Size.Small"
                                       Disabled="_editing"
                                       OnClick="() => StartEdit(context)" />
                    </MudTooltip>
                    <MudTooltip Text="@Loc["Delete"]">
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                                       Disabled="_editing"
                                       OnClick="() => DeleteLevel(context.Id)" />
                    </MudTooltip>
                </MudTd>
            </RowTemplate>
        </MudTable>
    </MudPaper>
}

@code {
    private List<LevelDto>? _levels;
    private string? _message;
    private Severity _messageSeverity = Severity.Info;

    private bool _editing;
    private bool _saving;
    private Guid? _editId;
    private string _editTitleEn = string.Empty;
    private string _editDescriptionEn = string.Empty;
    private string _editTitleNl = string.Empty;
    private string _editDescriptionNl = string.Empty;
    private int _editGridWidth = 10;
    private int _editGridHeight = 8;

    protected override async Task OnInitializedAsync()
    {
        await LoadLevels();
    }

    private async Task LoadLevels()
    {
        _levels = await ApiClient.GetAllLevelsAsync();
    }

    private void StartCreate()
    {
        _editId = null;
        _editTitleEn = string.Empty;
        _editDescriptionEn = string.Empty;
        _editTitleNl = string.Empty;
        _editDescriptionNl = string.Empty;
        _editGridWidth = 10;
        _editGridHeight = 8;
        _editing = true;
    }

    private void StartEdit(LevelDto level)
    {
        _editId = level.Id;
        _editTitleEn = level.LocalizedContent.TryGetValue("en", out var en) ? en.Title : level.Title;
        _editDescriptionEn = level.LocalizedContent.TryGetValue("en", out var enD) ? enD.Description : level.Description;
        _editTitleNl = level.LocalizedContent.TryGetValue("nl", out var nl) ? nl.Title : string.Empty;
        _editDescriptionNl = level.LocalizedContent.TryGetValue("nl", out var nlD) ? nlD.Description : string.Empty;
        _editGridWidth = level.GridWidth;
        _editGridHeight = level.GridHeight;
        _editing = true;
    }

    private void CancelEdit()
    {
        _editing = false;
        _editId = null;
    }

    private async Task SaveLevel()
    {
        if (string.IsNullOrWhiteSpace(_editTitleEn)) return;
        _saving = true;

        var localizedContent = new Dictionary<string, LocalizedLevelText>
        {
            ["en"] = new() { Title = _editTitleEn.Trim(), Description = _editDescriptionEn.Trim() },
            ["nl"] = new() { Title = _editTitleNl.Trim(), Description = _editDescriptionNl.Trim() }
        };

        if (_editId is null)
        {
            await ApiClient.CreateLevelAsync(_editTitleEn.Trim(), _editDescriptionEn.Trim(), _editGridWidth, _editGridHeight, localizedContent);
            _message = Loc["LevelCreated"].Value;
        }
        else
        {
            await ApiClient.UpdateLevelAsync(_editId.Value, _editTitleEn.Trim(), _editDescriptionEn.Trim(), _editGridWidth, _editGridHeight, localizedContent);
            _message = Loc["LevelUpdated"].Value;
        }

        _messageSeverity = Severity.Success;
        _editing = false;
        _editId = null;
        _saving = false;
        await LoadLevels();
    }

    private async Task MoveLevel(Guid id, int direction)
    {
        await ApiClient.ReorderLevelAsync(id, direction);
        await LoadLevels();
    }

    private async Task DeleteLevel(Guid id)
    {
        var success = await ApiClient.DeleteLevelAsync(id);
        _message = success ? Loc["LevelDeleted"].Value : Loc["LevelDeleteFailed"].Value;
        _messageSeverity = success ? Severity.Success : Severity.Error;
        await LoadLevels();
    }
}
