@page "/play"
@attribute [Microsoft.AspNetCore.Authorization.Authorize]
@using BlazorMonaco
@using BlazorMonaco.Editor
@using MetroMania.Application.DTOs
@using MetroMania.Domain.Enums
@using MetroMania.Web.Services
@using Microsoft.AspNetCore.SignalR.Client
@using System.Security.Claims
@implements IAsyncDisposable
@inject IJSRuntime JS
@inject IStringLocalizer<Localization> Loc
@inject MetroManiaApiClient ApiClient
@inject AuthenticationStateProvider AuthStateProvider
@inject IConfiguration Configuration
@inject CodeEditorBridge EditorBridge

<PageTitle>MetroMania - @Loc["Play"]</PageTitle>

<div class="d-flex align-center mb-1">
    <MudIcon Icon="@Icons.Material.Filled.SportsEsports" Class="mr-2" Color="Color.Primary" />
    <MudText Typo="Typo.h4" Style="font-weight: 700;">@Loc["Play"]</MudText>
</div>
<MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-6">@Loc["PlaySubtitle"]</MudText>

<MudPaper Elevation="0" Class="pa-5" Style="border: 1px solid var(--mud-palette-lines-default);">
    <MudText Typo="Typo.subtitle2" Class="mb-2" Style="font-weight: 600;">@Loc["BotCode"]</MudText>

    <div style="border: 1px solid var(--mud-palette-lines-default); border-radius: 8px; overflow: hidden; direction: ltr;">
        @if (_isReady)
        {
            <StandaloneCodeEditor @ref="_editor"
                                  Id="bot-code-editor"
                                  ConstructionOptions="EditorConstructionOptions"
                                  OnDidInit="OnEditorInit" />
        }
        else
        {
            <div style="height: 300px; display: flex; align-items: center; justify-content: center;">
                <MudProgressCircular Indeterminate="true" Color="Color.Primary" />
            </div>
        }
    </div>

    <div class="d-flex gap-2 mt-3">
        <MudButton Variant="Variant.Filled" Color="Color.Primary" Size="Size.Small"
                   StartIcon="@Icons.Material.Filled.CloudUpload"
                   OnClick="SubmitCode" Disabled="_submitting">
            @Loc["Submit"]
        </MudButton>
        <MudButton Variant="Variant.Outlined" Color="Color.Default" Size="Size.Small"
                   StartIcon="@Icons.Material.Filled.ContentPaste"
                   OnClick="PasteFromClipboard" Disabled="_submitting">
            @Loc["Paste"]
        </MudButton>
        <MudButton Variant="Variant.Outlined" Color="Color.Default" Size="Size.Small"
                   StartIcon="@Icons.Material.Filled.Clear"
                   OnClick="ClearCode" Disabled="_submitting">
            @Loc["Clear"]
        </MudButton>
        <MudSpacer />
        @if (!string.IsNullOrEmpty(_playerTemplateUrl))
        {
            <MudButton Variant="Variant.Outlined" Color="Color.Default" Size="Size.Small"
                       StartIcon="@Icons.Material.Filled.Download"
                       Href="@_playerTemplateUrl" Target="_blank">
                @Loc["DownloadPlayerProject"]
            </MudButton>
        }
    </div>

    @if (_submitting)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mt-3" Rounded="true" />
    }

    @if (_validationErrors is { Count: > 0 })
    {
        <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Class="mt-3"
                  ShowCloseIcon="true" CloseIconClicked="() => _validationErrors = null">
            <MudText Typo="Typo.subtitle2" Style="font-weight: 600;">@Loc["ValidationFailed"]</MudText>
            <ul style="margin: 4px 0 0 16px; padding: 0;">
                @foreach (var error in _validationErrors)
                {
                    <li><MudText Typo="Typo.body2">@error</MudText></li>
                }
            </ul>
        </MudAlert>
    }
</MudPaper>

<MudText Typo="Typo.h6" Class="mt-8 mb-3" Style="font-weight: 600;">
    <MudIcon Icon="@Icons.Material.Filled.History" Class="mr-1" Style="vertical-align: middle;" />
    @Loc["SubmissionHistory"]
</MudText>

@if (_submissions.Count == 0)
{
    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined" Class="mb-4">
        @Loc["NoSubmissionsYet"]
    </MudAlert>
}
else
{
    <MudExpansionPanels MultiExpansion="true" Elevation="0" Class="mb-4"
                        Style="border: 1px solid var(--mud-palette-lines-default); border-radius: 8px;">
        @foreach (var submission in _submissions)
        {
            <MudExpansionPanel Style="border-bottom: 1px solid var(--mud-palette-lines-default);">
                <TitleContent>
                    <div class="d-flex align-center justify-space-between" style="width: 100%;">
                        <div class="d-flex align-center gap-2">
                            <MudIcon Icon="@Icons.Material.Filled.Code" Size="Size.Small" Color="Color.Primary" />
                            <MudText Typo="Typo.body2" Style="font-weight: 600;">
                                @Loc["Submission"] #@submission.Version
                            </MudText>
                            <MudChip T="string" Size="Size.Small" Variant="Variant.Filled" Color="GetStatusColor(submission.Status)">
                                @Loc[submission.Status.ToString()]
                            </MudChip>
                            @if (submission.Status == SubmissionStatus.Succeeded)
                            {
                                <MudChip T="string" Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary">
                                    @Loc["TotalScore"]: @submission.TotalScore.ToString("N0")
                                </MudChip>
                            }
                        </div>
                        <div class="d-flex align-center gap-2" @onclick:stopPropagation="true">
                            <MudText Typo="Typo.caption" Color="Color.Secondary">
                                @submission.SubmittedAt.ToLocalTime().ToString("g")
                            </MudText>
                            <MudTooltip Text="@Loc["LoadToEditor"]">
                                <MudIconButton Icon="@Icons.Material.Filled.Edit"
                                               Size="Size.Small"
                                               Color="Color.Primary"
                                               OnClick="() => RevertToSubmission(submission)" />
                            </MudTooltip>
                        </div>
                    </div>
                </TitleContent>
                <ChildContent>
                    @if (!string.IsNullOrWhiteSpace(submission.Message))
                    {
                        <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Dense="true" Class="mb-3">
                            <MudText Typo="Typo.subtitle2" Style="font-weight: 600;" Class="mb-1">@Loc["FailureDetails"]</MudText>
                            <pre style="margin: 0; white-space: pre-wrap; word-break: break-word; font-family: 'Cascadia Code', 'Fira Code', 'Consolas', monospace; font-size: 12px;">@submission.Message</pre>
                        </MudAlert>
                    }
                    @if (submission.Scores.Count > 0)
                    {
                        <MudTable Items="submission.Scores" Dense="true" Hover="true" Elevation="0"
                                  Class="mb-3" Style="border: 1px solid var(--mud-palette-lines-default); border-radius: 6px;">
                            <HeaderContent>
                                <MudTh>@Loc["LevelName"]</MudTh>
                                <MudTh Style="text-align: right;">@Loc["Score"]</MudTh>
                                @if (submission.Status == SubmissionStatus.Succeeded)
                                {
                                    <MudTh Style="width: 0;" />
                                    <MudTh Style="width: 0;" />
                                }
                            </HeaderContent>
                            <RowTemplate>
                                <MudTd DataLabel="@Loc["LevelName"]">
                                    @context.GetLocalizedTitle()
                                    @if (!string.IsNullOrWhiteSpace(context.GetLocalizedDescription()))
                                    {
                                        <MudText Typo="Typo.caption" Color="Color.Secondary" Style="display: inline;"> — @context.GetLocalizedDescription()</MudText>
                                    }
                                </MudTd>
                                <MudTd DataLabel="@Loc["Score"]" Style="text-align: right;">
                                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Secondary">
                                        @context.Score.ToString("N0")
                                    </MudChip>
                                </MudTd>
                                @if (submission.Status == SubmissionStatus.Succeeded)
                                {
                                    <MudTd>
                                        <MudTooltip Text="@Loc["WatchReplays"]">
                                            <MudIconButton Icon="@Icons.Material.Filled.Slideshow"
                                                           Size="Size.Small"
                                                           Color="Color.Primary"
                                                           Href="@($"/play/renders?submissionId={submission.Id}&levelId={context.LevelId}")" />
                                        </MudTooltip>
                                    </MudTd>
                                    <MudTd>
                                        <MudTooltip Text="@Loc["DownloadZip"]">
                                            <MudIconButton Icon="@Icons.Material.Filled.FolderZip"
                                                           Size="Size.Small"
                                                           Color="Color.Secondary"
                                                           Href="@($"/api/downloads/submissions/{submission.Id}/levels/{context.LevelId}/zip")"
                                                           Target="_blank" />
                                        </MudTooltip>
                                    </MudTd>
                                }
                            </RowTemplate>
                            <FooterContent>
                                <MudTFootRow>
                                    <MudTd Style="font-weight: 700;">@Loc["TotalScore"]</MudTd>
                                    <MudTd Style="text-align: right; font-weight: 700;">
                                        <MudChip T="string" Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary">
                                            @submission.TotalScore.ToString("N0")
                                        </MudChip>
                                    </MudTd>
                                    @if (submission.Status == SubmissionStatus.Succeeded)
                                    {
                                        <MudTd />
                                        <MudTd />
                                    }
                                </MudTFootRow>
                            </FooterContent>
                        </MudTable>
                    }
                    <div style="border: 1px solid var(--mud-palette-lines-default); border-radius: 6px; overflow: hidden; max-height: 300px; overflow-y: auto;">
                        <pre style="margin: 0; padding: 12px; font-family: 'Cascadia Code', 'Fira Code', 'Consolas', monospace; font-size: 13px; background: var(--mud-palette-background-default); white-space: pre-wrap; word-break: break-word;">@submission.Code</pre>
                    </div>
                </ChildContent>
            </MudExpansionPanel>
        }
    </MudExpansionPanels>
}

@code {
    private StandaloneCodeEditor _editor = null!;
    private bool _isReady;
    private bool _editorReady;
    private bool _previousDarkMode;
    private bool _submitting;
    private Guid _userId;
    private string _starterCode = "";
    private string _initialCode = "";
    private List<SubmissionDto> _submissions = [];
    private IReadOnlyList<string>? _validationErrors;
    private HubConnection? _hubConnection;
    private string? _playerTemplateUrl;

    [CascadingParameter(Name = "IsDarkMode")]
    private bool IsDarkMode { get; set; }

    protected override async Task OnInitializedAsync()
    {
        _playerTemplateUrl = Configuration.GetValue<string>("PLAYER_TEMPLATE_URL");

        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var userIdClaim = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
        if (Guid.TryParse(userIdClaim, out var uid))
        {
            _userId = uid;
            _submissions = await ApiClient.GetUserSubmissionsAsync(_userId);
            await StartHubConnectionAsync();
        }

        _starterCode = await ApiClient.GetStarterCodeAsync();
        _initialCode = _submissions.Count > 0
            ? _submissions.MaxBy(s => s.Version)!.Code
            : _starterCode;

        if (_editorReady)
        {
            await _editor.SetValue(_initialCode);
            await UpdateEditorHeight();
        }
    }

    private async Task StartHubConnectionAsync()
    {
        var apiBaseUrl = Configuration.GetValue<string>("API_BASE_URL");
        if (string.IsNullOrEmpty(apiBaseUrl)) return;

        _hubConnection = new HubConnectionBuilder()
            .WithUrl($"{apiBaseUrl.TrimEnd('/')}/hubs/submissions")
            .WithAutomaticReconnect()
            .Build();

        _hubConnection.On<Guid, string>("SubmissionStatusChanged", async (submissionId, status) =>
        {
            _submissions = await ApiClient.GetUserSubmissionsAsync(_userId);
            await InvokeAsync(StateHasChanged);
        });

        try
        {
            await _hubConnection.StartAsync();
            await _hubConnection.InvokeAsync("JoinUserGroup", _userId.ToString());
        }
        catch
        {
            // Hub connection is best-effort; page still works without it
        }
    }

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            _previousDarkMode = IsDarkMode;
            _isReady = true;
            StateHasChanged();
            await Task.Delay(100);
        }
    }

    protected override async Task OnParametersSetAsync()
    {
        if (_isReady && IsDarkMode != _previousDarkMode)
        {
            _previousDarkMode = IsDarkMode;
            await BlazorMonaco.Editor.Global.SetTheme(JS, IsDarkMode ? "vs-dark" : "vs");
        }
    }

    private StandaloneEditorConstructionOptions EditorConstructionOptions(StandaloneCodeEditor editor)
    {
        return new StandaloneEditorConstructionOptions
        {
            AutomaticLayout = true,
            Language = "csharp",
            Theme = IsDarkMode ? "vs-dark" : "vs",
            Value = _initialCode,
            FontSize = 14,
            FontFamily = "'Cascadia Code', 'Fira Code', 'Consolas', monospace",
            Minimap = new EditorMinimapOptions { Enabled = false },
            ScrollBeyondLastLine = false,
            RenderLineHighlight = "all",
            Padding = new EditorPaddingOptions { Top = 10, Bottom = 10 },
            TabSize = 4,
            InsertSpaces = true
        };
    }

    private async Task OnEditorInit()
    {
        await Task.Delay(1000); // Ensure editor is fully initialized

        _editorReady = true;
        if (!string.IsNullOrEmpty(_initialCode))
            await EditorInteropWithRetryAsync(() => _editor.SetValue(_initialCode));
        await UpdateEditorHeight();

        EditorBridge.GetCode = async () => _editorReady ? await _editor.GetValue() : null;
        EditorBridge.SetCode = async (code) =>
        {
            if (!_editorReady) return;
            await _editor.SetValue(code);
            await UpdateEditorHeight();
            StateHasChanged();
        };
    }

    private async Task UpdateEditorHeight()
    {
        if (!_editorReady) return;
        await EditorInteropWithRetryAsync(async () =>
        {
            var model = await _editor.GetModel();
            var lineCount = await model.GetLineCount();
            var height = Math.Clamp(lineCount * 20 + 20, 300, 600);
            await JS.InvokeVoidAsync("eval",
                $"document.getElementById('bot-code-editor').style.height = '{height}px'");
        });
    }

    private static async Task EditorInteropWithRetryAsync(Func<Task> action, int maxRetries = 5)
    {
        for (var i = 0; i < maxRetries; i++)
        {
            try
            {
                await action();
                return;
            }
            catch (JSException) when (i < maxRetries - 1)
            {
                await Task.Delay(100 * (i + 1));
            }
        }
    }

    private async Task SubmitCode()
    {
        if (_userId == Guid.Empty) return;

        var code = await _editor.GetValue();
        if (string.IsNullOrWhiteSpace(code)) return;

        _validationErrors = null;
        _submitting = true;
        StateHasChanged();
        try
        {
            var result = await ApiClient.SubmitCodeAsync(_userId, code);

            if (!result.Success)
            {
                _validationErrors = result.ValidationErrors;
                return;
            }

            _submissions = await ApiClient.GetUserSubmissionsAsync(_userId);
        }
        finally
        {
            _submitting = false;
        }
    }

    private async Task PasteFromClipboard()
    {
        try
        {
            var text = await JS.InvokeAsync<string>("navigator.clipboard.readText");
            if (!string.IsNullOrEmpty(text))
            {
                await _editor.SetValue(text);
                await UpdateEditorHeight();
            }
        }
        catch
        {
            // Clipboard API may be blocked by browser permissions
        }
    }

    private async Task ClearCode()
    {
        await _editor.SetValue(_starterCode);
        await UpdateEditorHeight();
    }

    private async Task RevertToSubmission(SubmissionDto submission)
    {
        await _editor.SetValue(submission.Code);
        await UpdateEditorHeight();
    }

    private static Color GetStatusColor(SubmissionStatus status) => status switch
    {
        SubmissionStatus.Waiting => Color.Default,
        SubmissionStatus.Running => Color.Info,
        SubmissionStatus.Rendering => Color.Info,
        SubmissionStatus.Finalizing => Color.Info,
        SubmissionStatus.Succeeded => Color.Success,
        SubmissionStatus.Failed => Color.Error,
        _ => Color.Default
    };

    public async ValueTask DisposeAsync()
    {
        EditorBridge.GetCode = null;
        EditorBridge.SetCode = null;

        if (_hubConnection is not null)
        {
            await _hubConnection.DisposeAsync();
        }
    }
}
