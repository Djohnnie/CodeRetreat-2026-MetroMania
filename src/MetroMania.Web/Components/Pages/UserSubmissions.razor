@page "/admin/submissions/{UserId:guid}"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Admin")]
@using BlazorMonaco
@using BlazorMonaco.Editor
@using MetroMania.Application.DTOs
@using MetroMania.Domain.Enums
@using MetroMania.Web.Services
@inject MetroManiaApiClient ApiClient
@inject NavigationManager Navigation
@inject IJSRuntime JS
@inject IStringLocalizer<Localization> Loc
@inject ISnackbar Snackbar

<PageTitle>MetroMania - @Loc["UserSubmissions"]</PageTitle>

<MudButton Href="/admin/submissions" Variant="Variant.Text" StartIcon="@Icons.Material.Filled.ArrowBack"
           Color="Color.Primary" Class="mb-4">
    @Loc["BackToSubmissions"]
</MudButton>

<div class="d-flex align-center mb-1">
    <MudIcon Icon="@Icons.Material.Filled.Code" Class="mr-2" Color="Color.Primary" />
    <MudText Typo="Typo.h4" Style="font-weight: 700;">
        @if (_userName is not null)
        {
            @string.Format(Loc["UserSubmissionsTitle"], _userName)
        }
        else
        {
            @Loc["UserSubmissions"]
        }
    </MudText>
</div>
<MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-6">@Loc["UserSubmissionsSubtitle"]</MudText>

@if (_loading)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else if (_submissions is null || _submissions.Count == 0)
{
    <MudAlert Severity="Severity.Info" Variant="Variant.Outlined">@Loc["NoSubmissionsYet"]</MudAlert>
}
else
{
    <MudPaper Elevation="0" Style="border: 1px solid var(--mud-palette-lines-default); overflow: hidden;">
        <MudTable Items="_submissions" Hover="true" Elevation="0" Dense="true" Breakpoint="Breakpoint.Sm">
            <HeaderContent>
                <MudTh Style="width: 0;" />
                <MudTh>@Loc["Version"]</MudTh>
                <MudTh>@Loc["Status"]</MudTh>
                <MudTh>@Loc["TotalScore"]</MudTh>
                <MudTh>@Loc["SubmittedAt"]</MudTh>
                <MudTh>@Loc["CodePreview"]</MudTh>
                <MudTh Style="width: 0;" />
            </HeaderContent>
            <RowTemplate>
                <MudTd>
                    <MudIconButton Size="Size.Small"
                                   Icon="@(_expandedRows.Contains(context.Id) ? Icons.Material.Filled.ExpandLess : Icons.Material.Filled.ExpandMore)"
                                   OnClick="() => ToggleRow(context.Id)" />
                </MudTd>
                <MudTd DataLabel="@Loc["Version"]">
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Primary">
                        v@(context.Version)
                    </MudChip>
                </MudTd>
                <MudTd DataLabel="@Loc["Status"]">
                    @if (context.IsFinished)
                    {
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Filled" Color="Color.Success">@Loc["Finished"]</MudChip>
                    }
                    else if (context.IsFailed)
                    {
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Filled" Color="Color.Error">@Loc["Failed"]</MudChip>
                    }
                    else
                    {
                        <MudChip T="string" Size="Size.Small" Variant="Variant.Filled" Color="Color.Info">@Loc[context.RunStatus.ToString()] / @Loc[context.RenderStatus.ToString()]</MudChip>
                    }
                </MudTd>
                <MudTd DataLabel="@Loc["TotalScore"]">
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary">
                        @context.TotalScore.ToString("N0")
                    </MudChip>
                </MudTd>
                <MudTd DataLabel="@Loc["SubmittedAt"]">
                    <MudText Typo="Typo.body2" Color="Color.Secondary">
                        @context.SubmittedAt.ToString("yyyy-MM-dd HH:mm:ss")
                    </MudText>
                </MudTd>
                <MudTd DataLabel="@Loc["CodePreview"]">
                    <MudText Typo="Typo.body2" Style="font-family: monospace; max-width: 500px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                        @Truncate(context.Code, 100)
                    </MudText>
                </MudTd>
                <MudTd Style="text-align: right;">
                    <MudTooltip Text="@Loc["DeleteSubmission"]">
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Color="Color.Error" Size="Size.Small"
                                       OnClick="() => DeleteSubmission(context.Id, context.Version)" />
                    </MudTooltip>
                </MudTd>
            </RowTemplate>
            <ChildRowContent>
                @if (_expandedRows.Contains(context.Id))
                {
                    <MudTr>
                        <td colspan="7" style="padding: 0;">
                            <div class="pa-4" style="background: var(--mud-palette-background-grey);">
                                @if (!string.IsNullOrWhiteSpace(context.Message))
                                {
                                    <MudAlert Severity="Severity.Error" Variant="Variant.Outlined" Dense="true" Class="mb-3">
                                        <MudText Typo="Typo.subtitle2" Style="font-weight: 600;" Class="mb-1">@Loc["FailureDetails"]</MudText>
                                        <pre style="margin: 0; white-space: pre-wrap; word-break: break-word; font-family: 'Cascadia Code', 'Fira Code', 'Consolas', monospace; font-size: 12px;">@context.Message</pre>
                                    </MudAlert>
                                }
                                @if (context.Scores.Count > 0)
                                {
                                    <MudTable Items="context.Scores" Dense="true" Hover="true" Elevation="0"
                                              Class="mb-3" Style="border: 1px solid var(--mud-palette-lines-default); border-radius: 6px;">
                                        <HeaderContent>
                                            <MudTh>@Loc["LevelName"]</MudTh>
                                            <MudTh Style="text-align: right;">@Loc["Score"]</MudTh>
                                            <MudTh Style="width: 0;" />
                                            <MudTh Style="width: 0;" />
                                        </HeaderContent>
                                        <RowTemplate Context="scoreCtx">
                                            <MudTd DataLabel="@Loc["LevelName"]">
                                                @scoreCtx.GetLocalizedTitle()
                                                @if (!string.IsNullOrWhiteSpace(scoreCtx.GetLocalizedDescription()))
                                                {
                                                    <MudText Typo="Typo.caption" Color="Color.Secondary" Style="display: inline;"> — @scoreCtx.GetLocalizedDescription()</MudText>
                                                }
                                            </MudTd>
                                            <MudTd DataLabel="@Loc["Score"]" Style="text-align: right;">
                                                <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Secondary">
                                                    @scoreCtx.Score.ToString("N0")
                                                </MudChip>
                                            </MudTd>
                                            <MudTd>
                                                <MudTooltip Text="@Loc["ViewRenders"]">
                                                    <MudIconButton Size="Size.Small"
                                                                   Icon="@Icons.Material.Filled.Slideshow"
                                                                   Color="Color.Primary"
                                                                   Href="@($"/play/renders?submissionId={context.Id}&levelId={scoreCtx.LevelId}")" />
                                                </MudTooltip>
                                            </MudTd>
                                            <MudTd>
                                                <MudTooltip Text="@Loc["DownloadZip"]">
                                                    <MudIconButton Size="Size.Small"
                                                                   Icon="@Icons.Material.Filled.FolderZip"
                                                                   Color="Color.Secondary"
                                                                   Href="@($"/api/downloads/submissions/{context.Id}/levels/{scoreCtx.LevelId}/zip")"
                                                                   Target="_blank" />
                                                </MudTooltip>
                                            </MudTd>
                                        </RowTemplate>
                                        <FooterContent>
                                            <MudTFootRow>
                                                <MudTd Style="font-weight: 700;">@Loc["TotalScore"]</MudTd>
                                                <MudTd Style="text-align: right; font-weight: 700;">
                                                    <MudChip T="string" Size="Size.Small" Variant="Variant.Filled" Color="Color.Primary">
                                                        @_submissions!.First(s => s.Id == context.Id).TotalScore.ToString("N0")
                                                    </MudChip>
                                                </MudTd>
                                            </MudTFootRow>
                                        </FooterContent>
                                    </MudTable>
                                }
                                <div style="border: 1px solid var(--mud-palette-lines-default); border-radius: 8px; overflow: hidden; height: @(CalculateEditorHeight(context.Code))px; direction: ltr;">
                                    <StandaloneCodeEditor Id="@($"submission-{context.Id}")"
                                                          ConstructionOptions="@(e => ReadOnlyEditorOptions(context.Code))"
                                                          OnDidInit="() => SetEditorHeight(context.Id, context.Code)" />
                                </div>
                            </div>
                        </td>
                    </MudTr>
                }
            </ChildRowContent>
        </MudTable>
    </MudPaper>
}

@code {
    [Parameter] public Guid UserId { get; set; }

    [CascadingParameter(Name = "IsDarkMode")]
    private bool IsDarkMode { get; set; }

    private List<SubmissionDto>? _submissions;
    private string? _userName;
    private bool _loading = true;
    private bool _previousDarkMode;
    private readonly HashSet<Guid> _expandedRows = [];

    protected override async Task OnInitializedAsync()
    {
        var userTask = ApiClient.GetUserByIdAsync(UserId);
        var submissionsTask = ApiClient.GetUserSubmissionsAsync(UserId);

        await Task.WhenAll(userTask, submissionsTask);

        var user = await userTask;
        _userName = user?.Name;
        _submissions = await submissionsTask;
        _loading = false;
        _previousDarkMode = IsDarkMode;
    }

    protected override async Task OnParametersSetAsync()
    {
        if (IsDarkMode != _previousDarkMode)
        {
            _previousDarkMode = IsDarkMode;
            await BlazorMonaco.Editor.Global.SetTheme(JS, IsDarkMode ? "vs-dark" : "vs");
        }
    }

    private StandaloneEditorConstructionOptions ReadOnlyEditorOptions(string code) => new()
    {
        AutomaticLayout = true,
        Language = "csharp",
        Theme = IsDarkMode ? "vs-dark" : "vs",
        Value = code,
        ReadOnly = true,
        FontSize = 13,
        FontFamily = "'Cascadia Code', 'Fira Code', 'Consolas', monospace",
        Minimap = new EditorMinimapOptions { Enabled = false },
        ScrollBeyondLastLine = false,
        RenderLineHighlight = "none",
        Padding = new EditorPaddingOptions { Top = 10, Bottom = 10 },
        TabSize = 4
    };

    private async Task SetEditorHeight(Guid id, string code)
    {
        var height = CalculateEditorHeight(code);
        await JS.InvokeVoidAsync("eval",
            $"document.getElementById('submission-{id}').style.height = '{height}px'");
    }

    private static int CalculateEditorHeight(string code)
    {
        var lineCount = code.Split('\n').Length;
        return Math.Clamp(lineCount * 20 + 20, 100, 500);
    }

    private static string Truncate(string value, int maxLength) =>
        value.Length <= maxLength ? value : value[..maxLength] + "…";

    private void ToggleRow(Guid id)
    {
        if (!_expandedRows.Remove(id))
            _expandedRows.Add(id);
    }

    private async Task DeleteSubmission(Guid submissionId, int version)
    {
        _expandedRows.Remove(submissionId);
        var success = await ApiClient.DeleteSubmissionAsync(submissionId);
        if (success)
        {
            _submissions!.RemoveAll(s => s.Id == submissionId);
            Snackbar.Add(string.Format(Loc["SubmissionDeleted"], version), Severity.Success);
        }
        else
        {
            Snackbar.Add(Loc["SubmissionDeleteFailed"].Value, Severity.Error);
        }
    }

}
