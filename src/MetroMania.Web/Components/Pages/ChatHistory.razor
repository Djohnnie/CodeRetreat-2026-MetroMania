@page "/admin/chats"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Admin")]
@using MetroMania.Application.DTOs
@using MetroMania.Domain.Enums
@using MetroMania.Web.Services
@inject MetroManiaApiClient ApiClient
@inject IStringLocalizer<Localization> Loc

<PageTitle>MetroMania - @Loc["ChatHistory"]</PageTitle>

<div class="d-flex align-center mb-1">
    <MudIcon Icon="@Icons.Material.Filled.Forum" Class="mr-2" Color="Color.Primary" />
    <MudText Typo="Typo.h4" Style="font-weight: 700;">@Loc["ChatHistory"]</MudText>
</div>
<MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-6">@Loc["ChatHistorySubtitle"]</MudText>

@if (_users is null)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else
{
    <MudPaper Elevation="0" Style="border: 1px solid var(--mud-palette-lines-default); overflow: hidden;">
        <MudTable Items="_users" Hover="true" Elevation="0" Dense="true" Breakpoint="Breakpoint.Sm"
                  RowClass="cursor-pointer" RowClassFunc="@((user, _) => user.Id == _selectedUserId ? "mud-primary-text" : "")"
                  OnRowClick="OnUserRowClicked" T="UserDto">
            <HeaderContent>
                <MudTh>@Loc["Name"]</MudTh>
                <MudTh>@Loc["Role"]</MudTh>
                <MudTh>@Loc["Status"]</MudTh>
            </HeaderContent>
            <RowTemplate>
                <MudTd DataLabel="@Loc["Name"]">
                    <div class="d-flex align-center">
                        <MudAvatar Size="Size.Small" Color="Color.Primary" Variant="Variant.Outlined" Class="mr-2">
                            @context.Name[0].ToString().ToUpper()
                        </MudAvatar>
                        @context.Name
                    </div>
                </MudTd>
                <MudTd DataLabel="@Loc["Role"]">
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                             Color="@(context.Role == UserRole.Admin ? Color.Primary : Color.Default)">
                        @context.Role
                    </MudChip>
                </MudTd>
                <MudTd DataLabel="@Loc["Status"]">
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Filled" Color="@GetStatusColor(context.ApprovalStatus)">
                        @Loc[context.ApprovalStatus.ToString()]
                    </MudChip>
                </MudTd>
            </RowTemplate>
        </MudTable>
    </MudPaper>

    @if (_selectedUserId is null)
    {
        <MudAlert Severity="Severity.Info" Variant="Variant.Text" Class="mt-4" Dense="true">
            @Loc["SelectUserToViewChat"]
        </MudAlert>
    }
    else if (_loadingChat)
    {
        <MudProgressLinear Indeterminate="true" Color="Color.Primary" Class="mt-4" />
    }
    else if (_chatMessages is not null)
    {
        <MudPaper Elevation="0" Class="mt-4 pa-4" Style="border: 1px solid var(--mud-palette-lines-default);">
            <div class="d-flex align-center mb-3">
                <MudIcon Icon="@Icons.Material.Filled.SmartToy" Class="mr-2" />
                <MudText Typo="Typo.subtitle1" Style="font-weight: 700;">
                    @Loc["ChatHistory"] — @_selectedUserName
                </MudText>
            </div>

            @if (_chatMessages.Count == 0)
            {
                <MudAlert Severity="Severity.Normal" Variant="Variant.Text" Dense="true">
                    @Loc["NoChatMessages"]
                </MudAlert>
            }
            else
            {
                <div style="max-height: 600px; overflow-y: auto; padding: 8px 4px;">
                    @foreach (var msg in _chatMessages)
                    {
                        <MudXChat ChatPosition="@(msg.Author == ChatMessageAuthor.User ? ChatBubblePosition.End : ChatBubblePosition.Start)"
                                  Dense="true" Class="mb-2"
                                  Style="@(msg.IsArchived ? "opacity: 0.45;" : "")">
                            @foreach (var part in msg.Content.Split("[BR]", StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries))
                            {
                                <MudXChatBubble>@part</MudXChatBubble>
                            }
                            <MudXChatBubble>
                                <div class="d-flex align-center gap-2">
                                    <MudText Typo="Typo.caption" Color="Color.Secondary" Style="font-size: 0.7rem;">
                                        @msg.Timestamp.ToString("yyyy-MM-dd HH:mm:ss")
                                    </MudText>
                                    @if (msg.IsArchived)
                                    {
                                        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined"
                                                 Color="Color.Default" Style="font-size: 0.65rem; height: 18px;">
                                            @Loc["Archived"]
                                        </MudChip>
                                    }
                                </div>
                            </MudXChatBubble>
                        </MudXChat>
                    }
                </div>
            }
        </MudPaper>
    }
}

@code {
    private List<UserDto>? _users;
    private Guid? _selectedUserId;
    private string _selectedUserName = string.Empty;
    private List<ChatMessageDto>? _chatMessages;
    private bool _loadingChat;

    protected override async Task OnInitializedAsync()
    {
        _users = await ApiClient.GetAllUsersAsync();
    }

    private async Task OnUserRowClicked(TableRowClickEventArgs<UserDto> args)
    {
        var user = args.Item;
        if (user is null) return;

        _selectedUserId = user.Id;
        _selectedUserName = user.Name;
        _chatMessages = null;
        _loadingChat = true;
        StateHasChanged();

        try
        {
            _chatMessages = await ApiClient.GetFullChatHistoryAsync(user.Id);
        }
        catch
        {
            _chatMessages = [];
        }
        finally
        {
            _loadingChat = false;
        }
    }

    private Color GetStatusColor(ApprovalStatus status) => status switch
    {
        ApprovalStatus.Approved => Color.Success,
        ApprovalStatus.Pending => Color.Warning,
        ApprovalStatus.Rejected => Color.Error,
        _ => Color.Default
    };
}
