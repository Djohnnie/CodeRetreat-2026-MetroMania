@page "/admin/levels/{LevelId:guid}"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Admin")]
@using MetroMania.Application.DTOs
@using MetroMania.Domain.Entities
@using MetroMania.Domain.Enums
@using MetroMania.Web.Services
@using MudBlazor.Utilities
@inject MetroManiaApiClient ApiClient
@inject NavigationManager Navigation
@inject IStringLocalizer<Localization> Loc
@inject IWebHostEnvironment Env
@implements IDisposable

<PageTitle>MetroMania - @Loc["EditGrid"]</PageTitle>

@if (_level is null)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else
{
    <MudButton Href="/admin/levels" Variant="Variant.Text" StartIcon="@Icons.Material.Filled.ArrowBack"
               Color="Color.Primary" Class="mb-4">
        @Loc["BackToLevels"]
    </MudButton>

    <div class="d-flex align-center mb-1">
        <MudIcon Icon="@Icons.Material.Filled.GridOn" Class="mr-2" Color="Color.Primary" />
        <MudText Typo="Typo.h4" Style="font-weight: 700;">@_level.Title</MudText>
        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Info" Class="ml-3">
            @_level.GridWidth x @_level.GridHeight
        </MudChip>
    </div>
    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-6">@Loc["EditGridSubtitle"]</MudText>

    <!-- Color pickers -->
    <div class="d-flex justify-center mb-4">
        <MudPaper Class="pa-3 d-flex align-center gap-4 flex-wrap" Elevation="0"
                  Style="border: 1px solid var(--mud-palette-lines-default); display: inline-flex;">
            <div class="d-flex align-center gap-2">
                <MudText Typo="Typo.body2" Style="font-weight: 600;">@Loc["BackgroundColor"]:</MudText>
                <MudColorPicker Value="_backgroundColor"
                                ValueChanged="OnBackgroundColorChanged"
                                Placeholder="@Loc["BackgroundColor"]"
                                PickerVariant="PickerVariant.Inline"
                                ColorPickerMode="ColorPickerMode.HEX"
                                Style="max-width: 140px;"
                                Variant="Variant.Outlined" />
            </div>
            <MudDivider Vertical="true" FlexItem="true" />
            <div class="d-flex align-center gap-2">
                <MudText Typo="Typo.body2" Style="font-weight: 600;">@Loc["WaterColor"]:</MudText>
                <MudColorPicker Value="_waterColor"
                                ValueChanged="OnWaterColorChanged"
                                Placeholder="@Loc["WaterColor"]"
                                PickerVariant="PickerVariant.Inline"
                                ColorPickerMode="ColorPickerMode.HEX"
                                Style="max-width: 140px;"
                                Variant="Variant.Outlined" />
            </div>
            <MudDivider Vertical="true" FlexItem="true" />
            <div class="d-flex align-center gap-2">
                <MudText Typo="Typo.body2" Style="font-weight: 600;">@Loc["Seed"]:</MudText>
                <MudNumericField Value="_seed" ValueChanged="OnSeedChanged" T="int"
                                 Variant="Variant.Outlined" Style="max-width: 140px;" />
            </div>
        </MudPaper>
    </div>

    <!-- Station toolbar -->
    <div class="d-flex justify-center mb-4">
        <MudPaper Class="pa-3 d-flex align-center gap-2 flex-wrap" Elevation="0"
                  Style="border: 1px solid var(--mud-palette-lines-default); display: inline-flex;">
            <MudText Typo="Typo.body2" Style="font-weight: 600;" Class="mr-2">@Loc["StationTypes"]:</MudText>

            <MudChip T="string" Size="Size.Small" Class="mr-1" Style="font-weight: 600; opacity: 0.5;">@Loc["Beginner"]</MudChip>
            @foreach (var st in _beginnerTypes)
            {
                <MudTooltip Text="@Loc[st.ToString()]">
                    <MudButton Variant="@(_toolMode == ToolMode.Station && _selectedType == st ? Variant.Filled : Variant.Outlined)"
                               Color="@(_toolMode == ToolMode.Station && _selectedType == st ? Color.Primary : Color.Default)"
                               Size="Size.Small" OnClick="() => SelectType(st)"
                               Style="min-width: 40px; text-transform: none;">
                        <div style="position:relative;display:inline-block;width:24px;height:24px;flex-shrink:0;">@((MarkupString)GetTileSvg(GetStationTileSvgName(st)))</div>
                    </MudButton>
                </MudTooltip>
            }

            <MudDivider Vertical="true" FlexItem="true" Class="mx-2" />

            <MudChip T="string" Size="Size.Small" Class="mr-1" Style="font-weight: 600; opacity: 0.5;">@Loc["Advanced"]</MudChip>
            @foreach (var st in _advancedTypes)
            {
                <MudTooltip Text="@Loc[st.ToString()]">
                    <MudButton Variant="@(_toolMode == ToolMode.Station && _selectedType == st ? Variant.Filled : Variant.Outlined)"
                               Color="@(_toolMode == ToolMode.Station && _selectedType == st ? Color.Primary : Color.Default)"
                               Size="Size.Small" OnClick="() => SelectType(st)"
                               Style="min-width: 40px; text-transform: none;">
                        <div style="position:relative;display:inline-block;width:24px;height:24px;flex-shrink:0;">@((MarkupString)GetTileSvg(GetStationTileSvgName(st)))</div>
                    </MudButton>
                </MudTooltip>
            }

            <MudDivider Vertical="true" FlexItem="true" Class="mx-2" />

            <MudTooltip Text="@Loc["Water"]">
                <MudButton Variant="@(_toolMode == ToolMode.Water ? Variant.Filled : Variant.Outlined)"
                           Color="@(_toolMode == ToolMode.Water ? Color.Info : Color.Default)"
                           Size="Size.Small" OnClick="SelectWater"
                           Style="min-width: 40px; text-transform: none;">
                    <MudIcon Icon="@Icons.Material.Filled.Water" Size="Size.Small" />
                </MudButton>
            </MudTooltip>

            <MudTooltip Text="@Loc["Eraser"]">
                <MudButton Variant="@(_toolMode == ToolMode.Eraser ? Variant.Filled : Variant.Outlined)"
                           Color="@(_toolMode == ToolMode.Eraser ? Color.Error : Color.Default)"
                           Size="Size.Small" OnClick="SelectEraser"
                           Style="min-width: 40px; text-transform: none;">
                    <MudIcon Icon="@Icons.Material.Filled.Delete" Size="Size.Small" />
                </MudButton>
            </MudTooltip>
        </MudPaper>
    </div>

    <!-- Centered grid -->
    <div class="d-flex justify-center">
        <MudPaper Class="pa-4" Elevation="0" Style="border: 1px solid var(--mud-palette-lines-default); display: inline-block;">
            <div style="display: inline-grid; grid-template-columns: repeat(@_level.GridWidth, @(TileSize)px); gap: 0;">
                @for (var y = 0; y < _level.GridHeight; y++)
                {
                    @for (var x = 0; x < _level.GridWidth; x++)
                    {
                        var cx = x;
                        var cy = y;
                        var station = GetStationAt(cx, cy);
                        var isWater = IsWaterAt(cx, cy);
                        <div class="grid-tile" style="width: @(TileSize)px; height: @(TileSize)px;"
                             @onclick="() => OnTileClick(cx, cy)">
                            @((MarkupString)GetTileSvg("background"))
                            @if (isWater)
                            {
                                bool n = IsWaterAt(cx, cy - 1);
                                bool e = IsWaterAt(cx + 1, cy);
                                bool s = IsWaterAt(cx, cy + 1);
                                bool w = IsWaterAt(cx - 1, cy);
                                bool ne = n && e && IsWaterAt(cx + 1, cy - 1);
                                bool se = e && s && IsWaterAt(cx + 1, cy + 1);
                                bool sw = s && w && IsWaterAt(cx - 1, cy + 1);
                                bool nw = w && n && IsWaterAt(cx - 1, cy - 1);
                                @((MarkupString)GetTileSvg(GetWaterTileName(n, ne, e, se, s, sw, w, nw)))
                            }
                            @if (station is not null)
                            {
                                @((MarkupString)GetTileSvg(GetStationTileSvgName(station.StationType)))
                                <span class="spawn-delay-badge">@station.SpawnDelayDays</span>
                            }
                        </div>
                    }
                }
            </div>
        </MudPaper>
    </div>

    <!-- Station properties dialog -->
    <MudDialog @bind-Visible="_showStationDialog" Options="@(new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true })">
        <TitleContent>
            <div class="d-flex align-center gap-2">
                <div style="position:relative;display:inline-block;width:24px;height:24px;flex-shrink:0;">@((MarkupString)GetTileSvg(GetStationTileSvgName(_editShape)))</div>
                <MudText Typo="Typo.h6" Style="font-weight: 600;">@Loc["StationProperties"]</MudText>
            </div>
        </TitleContent>
        <DialogContent>
            <MudNumericField @bind-Value="_editSpawnDelayDays" Label="@Loc["SpawnDelay"]"
                             Variant="Variant.Outlined" Min="0" Class="mb-3" />
            <MudSelect @bind-Value="_editShape" Label="@Loc["Shape"]"
                       Variant="Variant.Outlined" Class="mb-3">
                @foreach (var st in Enum.GetValues<StationType>())
                {
                    <MudSelectItem Value="st">
                        <div class="d-flex align-center gap-2">
                            <div style="position:relative;display:inline-block;width:20px;height:20px;flex-shrink:0;">@((MarkupString)GetTileSvg(GetStationTileSvgName(st)))</div>
                            @Loc[st.ToString()]
                        </div>
                    </MudSelectItem>
                }
            </MudSelect>
            <MudText Typo="Typo.subtitle2" Class="mb-2">@Loc["SpawnFrequency"]</MudText>
            <MudTable Items="_editSpawnPhases" Dense="true" Elevation="0" Class="mb-3" Style="border: 1px solid var(--mud-palette-lines-default); border-radius: 4px;">
                <HeaderContent>
                    <MudTh>@Loc["AfterDays"]</MudTh>
                    <MudTh>@Loc["FrequencyInHours"]</MudTh>
                    <MudTh Style="width: 48px;"></MudTh>
                </HeaderContent>
                <RowTemplate>
                    <MudTd>
                        <MudNumericField @bind-Value="context.AfterDays" Min="0" Variant="Variant.Text" Margin="Margin.Dense" />
                    </MudTd>
                    <MudTd>
                        <MudNumericField @bind-Value="context.FrequencyInHours" Min="1" Variant="Variant.Text" Margin="Margin.Dense" />
                    </MudTd>
                    <MudTd>
                        <MudIconButton Icon="@Icons.Material.Filled.Delete" Size="Size.Small" OnClick="() => _editSpawnPhases.Remove(context)" />
                    </MudTd>
                </RowTemplate>
            </MudTable>
            <MudButton StartIcon="@Icons.Material.Filled.Add" Size="Size.Small" Variant="Variant.Text"
                       OnClick='() => _editSpawnPhases.Add(new PassengerSpawnPhase { AfterDays = _editSpawnPhases.Count > 0 ? _editSpawnPhases.Max(p => p.AfterDays) + 3 : 0, FrequencyInHours = _editSpawnPhases.Count > 0 ? Math.Max(1, _editSpawnPhases.Last().FrequencyInHours / 2) : 8 })'
                       Class="mb-3">@Loc["AddPhase"]</MudButton>
        </DialogContent>
        <DialogActions>
            <MudButton OnClick="CancelStationDialog" Variant="Variant.Text">@Loc["Cancel"]</MudButton>
            <MudButton OnClick="SaveStationProperties" Variant="Variant.Filled" Color="Color.Primary">@Loc["Save"]</MudButton>
        </DialogActions>
    </MudDialog>
}

<style>
    .grid-tile {
        position: relative;
        cursor: pointer;
        transition: opacity 0.15s, transform 0.1s;
        overflow: hidden;
    }
    .grid-tile:hover {
        opacity: 0.75;
        transform: scale(1.05);
        z-index: 1;
    }
    .spawn-delay-badge {
        position: absolute;
        bottom: 1px;
        right: 2px;
        font-size: 10px;
        font-weight: 700;
        color: white;
        text-shadow: 0 0 3px rgba(0,0,0,0.7);
        line-height: 1;
        pointer-events: none;
        z-index: 2;
    }
</style>

@code {
    [Parameter] public Guid LevelId { get; set; }

    private const int TileSize = 48;
    private const string SourceBackgroundColor = "rgb(255,227,214)";
    private const string SourceWaterColor = "rgb(182,227,243)";

    private enum ToolMode { Station, Water, Eraser }

    private LevelDto? _level;
    private List<MetroStation> _stations = [];
    private List<Water> _waterTiles = [];
    private HashSet<(int X, int Y)> _waterSet = [];
    private StationType _selectedType = StationType.Circle;
    private ToolMode _toolMode = ToolMode.Station;

    private MudColor _backgroundColor = new("#e8f5e9");
    private MudColor _waterColor = new("#90caf9");
    private int _seed;

    private CancellationTokenSource? _debounceCts;
    private readonly SemaphoreSlim _saveLock = new(1, 1);

    private static readonly StationType[] _beginnerTypes = [StationType.Circle, StationType.Rectangle, StationType.Triangle];
    private static readonly StationType[] _advancedTypes = [StationType.Diamond, StationType.Pentagon, StationType.Star];

    private Dictionary<string, string> _rawSvgCache = new();
    private Dictionary<string, string> _colorizedSvgCache = new();

    protected override async Task OnInitializedAsync()
    {
        _level = await ApiClient.GetLevelAsync(LevelId);
        if (_level is not null)
        {
            _stations = _level.Stations.Select(s => new MetroStation
            {
                GridX = s.GridX,
                GridY = s.GridY,
                StationType = s.StationType,
                SpawnDelayDays = s.SpawnDelayDays,
                PassengerSpawnPhases = s.PassengerSpawnPhases.Select(p => new PassengerSpawnPhase { AfterDays = p.AfterDays, FrequencyInHours = p.FrequencyInHours }).ToList(),
            }).ToList();
            _waterTiles = _level.WaterTiles.Select(w => new Water
            {
                GridX = w.GridX,
                GridY = w.GridY
            }).ToList();
            RebuildWaterSet();
            _backgroundColor = new MudColor(_level.BackgroundColor);
            _waterColor = new MudColor(_level.WaterColor);
            _seed = _level.Seed;
            LoadTileSvgs();
        }
    }

    private MetroStation? GetStationAt(int x, int y) =>
        _stations.FirstOrDefault(s => s.GridX == x && s.GridY == y);

    private bool IsWaterAt(int x, int y) =>
        x < 0 || y < 0 || x >= _level!.GridWidth || y >= _level.GridHeight
        || _waterSet.Contains((x, y));

    private void RebuildWaterSet() =>
        _waterSet = new HashSet<(int X, int Y)>(_waterTiles.Select(w => (w.GridX, w.GridY)));

    private void SelectType(StationType type)
    {
        _selectedType = type;
        _toolMode = ToolMode.Station;
    }

    private void SelectWater() => _toolMode = ToolMode.Water;
    private void SelectEraser() => _toolMode = ToolMode.Eraser;

    private string GetBackgroundHex() =>
        $"#{_backgroundColor.R:X2}{_backgroundColor.G:X2}{_backgroundColor.B:X2}";

    private string GetWaterHex() =>
        $"#{_waterColor.R:X2}{_waterColor.G:X2}{_waterColor.B:X2}";

    private async Task OnBackgroundColorChanged(MudColor color)
    {
        _backgroundColor = color;
        RebuildColorizedCache();
        await DebouncedSaveLevelData();
    }

    private async Task OnWaterColorChanged(MudColor color)
    {
        _waterColor = color;
        RebuildColorizedCache();
        await DebouncedSaveLevelData();
    }

    private async Task OnSeedChanged(int seed)
    {
        _seed = seed;
        await DebouncedSaveLevelData();
    }

    private MetroStation? _editingStation;
    private bool _showStationDialog;
    private int _editSpawnDelayDays;
    private StationType _editShape;
    private List<PassengerSpawnPhase> _editSpawnPhases = [];

    private async Task OnTileClick(int x, int y)
    {
        if (_level is null) return;

        var existingStation = GetStationAt(x, y);
        var isWater = IsWaterAt(x, y);

        switch (_toolMode)
        {
            case ToolMode.Eraser:
                if (existingStation is not null)
                {
                    _stations.Remove(existingStation);
                }
                if (isWater)
                {
                    _waterTiles.RemoveAll(w => w.GridX == x && w.GridY == y);
                    RebuildWaterSet();
                }
                break;

            case ToolMode.Water:
                if (isWater)
                {
                    _waterTiles.RemoveAll(w => w.GridX == x && w.GridY == y);
                }
                else if (existingStation is null)
                {
                    _waterTiles.Add(new Water { GridX = x, GridY = y });
                }
                RebuildWaterSet();
                break;

            case ToolMode.Station:
                if (isWater)
                    break;

                if (existingStation is not null)
                {
                    OpenStationDialog(existingStation);
                    return; // Don't save yet — dialog handles it
                }
                else
                {
                    _stations.Add(new MetroStation
                    {
                        GridX = x,
                        GridY = y,
                        StationType = _selectedType,
                        PassengerSpawnPhases = [new() { AfterDays = 0, FrequencyInHours = 8 }],
                    });
                }
                break;
        }

        await SaveLevelData();
    }

    private void OpenStationDialog(MetroStation station)
    {
        _editingStation = station;
        _editSpawnDelayDays = station.SpawnDelayDays;
        _editShape = station.StationType;
        _editSpawnPhases = station.PassengerSpawnPhases.Select(p => new PassengerSpawnPhase { AfterDays = p.AfterDays, FrequencyInHours = p.FrequencyInHours }).ToList();
        _showStationDialog = true;
    }

    private async Task SaveStationProperties()
    {
        if (_editingStation is not null)
        {
            _editingStation.SpawnDelayDays = _editSpawnDelayDays;
            _editingStation.StationType = _editShape;
            _editingStation.PassengerSpawnPhases = _editSpawnPhases.OrderBy(p => p.AfterDays).ToList();
        }
        _showStationDialog = false;
        _editingStation = null;
        await SaveLevelData();
    }

    private void CancelStationDialog()
    {
        _showStationDialog = false;
        _editingStation = null;
    }

    private async Task DebouncedSaveLevelData()
    {
        _debounceCts?.Cancel();
        _debounceCts = new CancellationTokenSource();
        var token = _debounceCts.Token;

        try
        {
            await Task.Delay(300, token);
            await SaveLevelData();
        }
        catch (TaskCanceledException) { }
    }

    private async Task SaveLevelData()
    {
        await _saveLock.WaitAsync();
        try
        {
            var data = new LevelData
            {
                BackgroundColor = GetBackgroundHex(),
                WaterColor = GetWaterHex(),
                Seed = _seed,
                Stations = _stations,
                WaterTiles = _waterTiles
            };
            await ApiClient.UpdateGridDataAsync(LevelId, data);
        }
        finally
        {
            _saveLock.Release();
        }
    }

    // --- SVG tile rendering ---

    private void LoadTileSvgs()
    {
        var tilesPath = Path.Combine(Env.ContentRootPath, "..", "..", "resources");
        tilesPath = Path.GetFullPath(tilesPath);
        if (!Directory.Exists(tilesPath))
            return;

        foreach (var file in Directory.GetFiles(tilesPath, "*.svg"))
        {
            var name = Path.GetFileNameWithoutExtension(file);
            _rawSvgCache[name] = File.ReadAllText(file);
        }

        RebuildColorizedCache();
    }

    private void RebuildColorizedCache()
    {
        _colorizedSvgCache.Clear();
        var bgHex = GetBackgroundHex();
        var waterHex = GetWaterHex();

        foreach (var (name, raw) in _rawSvgCache)
        {
            var svg = raw;

            // Strip XML declaration and DOCTYPE
            var svgStart = svg.IndexOf("<svg");
            if (svgStart > 0) svg = svg[svgStart..];

            // Remove explicit width/height, add absolute positioning for layering
            svg = svg.Replace("width=\"100%\" height=\"100%\" ", "");
            svg = svg.Replace("style=\"", "style=\"position:absolute;inset:0;width:100%;height:100%;pointer-events:none;");

            // Replace baked-in tile colors with level-specific colors
            svg = svg.Replace(SourceBackgroundColor, bgHex);
            svg = svg.Replace(SourceWaterColor, waterHex);

            _colorizedSvgCache[name] = svg;
        }
    }

    private string GetTileSvg(string tileName)
    {
        if (_colorizedSvgCache.TryGetValue(tileName, out var svg))
            return svg;

        // Fallback: use the "all relevant diags water" version
        var fallback = GetFallbackTileName(tileName);
        if (fallback is not null && _colorizedSvgCache.TryGetValue(fallback, out svg))
            return svg;

        return "";
    }

    /// <summary>
    /// Rebuilds tile name with all relevant diagonals set to water (the base tile).
    /// </summary>
    private static string? GetFallbackTileName(string tileName)
    {
        if (!tileName.StartsWith("water"))
            return null;

        var suffix = tileName == "water" ? "" : tileName["water-".Length..];
        var parts = suffix.Length > 0 ? suffix.Split('-') : [];
        var dirs = new HashSet<string>(parts);

        bool n = dirs.Contains("N"), e = dirs.Contains("E"),
             s = dirs.Contains("S"), w = dirs.Contains("W");

        var fb = new List<string>(8);
        if (n) fb.Add("N");
        if (n && e) fb.Add("NE");
        if (e) fb.Add("E");
        if (e && s) fb.Add("SE");
        if (s) fb.Add("S");
        if (s && w) fb.Add("SW");
        if (w) fb.Add("W");
        if (w && n) fb.Add("NW");
        return fb.Count == 0 ? "water" : "water-" + string.Join("-", fb);
    }

    private static string GetWaterTileName(bool n, bool ne, bool e, bool se, bool s, bool sw, bool w, bool nw)
    {
        var parts = new List<string>(8);
        if (n) parts.Add("N");
        if (n && e && ne) parts.Add("NE");
        if (e) parts.Add("E");
        if (e && s && se) parts.Add("SE");
        if (s) parts.Add("S");
        if (s && w && sw) parts.Add("SW");
        if (w) parts.Add("W");
        if (w && n && nw) parts.Add("NW");
        return parts.Count == 0 ? "water" : "water-" + string.Join("-", parts);
    }

    private static string GetStationTileSvgName(StationType type) => type switch
    {
        StationType.Circle => "station-circle",
        StationType.Rectangle => "station-square",
        StationType.Triangle => "station-triangle",
        StationType.Diamond => "station-diamond",
        StationType.Pentagon => "station-pentagon",
        StationType.Star => "station-star",
        _ => ""
    };

    public void Dispose()
    {
        _debounceCts?.Cancel();
        _debounceCts?.Dispose();
        _saveLock.Dispose();
    }
}
