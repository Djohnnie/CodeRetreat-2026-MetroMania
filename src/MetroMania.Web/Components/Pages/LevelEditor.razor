@page "/admin/levels/{LevelId:guid}"
@attribute [Microsoft.AspNetCore.Authorization.Authorize(Roles = "Admin")]
@using MediatR
@using MetroMania.Application.DTOs
@using MetroMania.Application.Levels.Commands
@using MetroMania.Application.Levels.Queries
@using MetroMania.Domain.Entities
@using MetroMania.Domain.Enums
@inject IMediator Mediator
@inject NavigationManager Navigation
@inject IStringLocalizer<Localization> Loc

<PageTitle>MetroMania - @Loc["EditGrid"]</PageTitle>

@if (_level is null)
{
    <MudProgressLinear Indeterminate="true" Color="Color.Primary" />
}
else
{
    <div class="d-flex align-center mb-1">
        <MudIconButton Icon="@Icons.Material.Filled.ArrowBack" OnClick="GoBack" Class="mr-1" />
        <MudIcon Icon="@Icons.Material.Filled.GridOn" Class="mr-2" Color="Color.Primary" />
        <MudText Typo="Typo.h4" Style="font-weight: 700;">@_level.Title</MudText>
        <MudChip T="string" Size="Size.Small" Variant="Variant.Outlined" Color="Color.Info" Class="ml-3">
            @_level.GridWidth x @_level.GridHeight
        </MudChip>
    </div>
    <MudText Typo="Typo.body2" Color="Color.Secondary" Class="mb-4">@Loc["EditGridSubtitle"]</MudText>

    <!-- Station toolbar -->
    <div class="d-flex justify-center mb-4">
        <MudPaper Class="pa-3 d-flex align-center gap-2 flex-wrap" Elevation="0"
                  Style="border: 1px solid var(--mud-palette-lines-default); display: inline-flex;">
            <MudText Typo="Typo.body2" Style="font-weight: 600;" Class="mr-2">@Loc["StationTypes"]:</MudText>

            <MudChip T="string" Size="Size.Small" Class="mr-1" Style="font-weight: 600; opacity: 0.5;">@Loc["Beginner"]</MudChip>
            @foreach (var st in _beginnerTypes)
            {
                <MudTooltip Text="@Loc[st.ToString()]">
                    <MudButton Variant="@(_selectedType == st && !_eraseMode ? Variant.Filled : Variant.Outlined)"
                               Color="@(_selectedType == st && !_eraseMode ? Color.Primary : Color.Default)"
                               Size="Size.Small" OnClick="() => SelectType(st)"
                               Style="min-width: 40px; text-transform: none;">
                        <svg width="20" height="20" viewBox="0 0 20 20">@GetStationSvg(st)</svg>
                    </MudButton>
                </MudTooltip>
            }

            <MudDivider Vertical="true" FlexItem="true" Class="mx-2" />

            <MudChip T="string" Size="Size.Small" Class="mr-1" Style="font-weight: 600; opacity: 0.5;">@Loc["Advanced"]</MudChip>
            @foreach (var st in _advancedTypes)
            {
                <MudTooltip Text="@Loc[st.ToString()]">
                    <MudButton Variant="@(_selectedType == st && !_eraseMode ? Variant.Filled : Variant.Outlined)"
                               Color="@(_selectedType == st && !_eraseMode ? Color.Primary : Color.Default)"
                               Size="Size.Small" OnClick="() => SelectType(st)"
                               Style="min-width: 40px; text-transform: none;">
                        <svg width="20" height="20" viewBox="0 0 20 20">@GetStationSvg(st)</svg>
                    </MudButton>
                </MudTooltip>
            }

            <MudDivider Vertical="true" FlexItem="true" Class="mx-2" />

            <MudTooltip Text="@Loc["Eraser"]">
                <MudButton Variant="@(_eraseMode ? Variant.Filled : Variant.Outlined)"
                           Color="@(_eraseMode ? Color.Error : Color.Default)"
                           Size="Size.Small" OnClick="ToggleEraser"
                           Style="min-width: 40px; text-transform: none;">
                    <MudIcon Icon="@Icons.Material.Filled.Delete" Size="Size.Small" />
                </MudButton>
            </MudTooltip>
        </MudPaper>
    </div>

    <!-- Centered grid -->
    <div class="d-flex justify-center">
        <MudPaper Class="pa-4" Elevation="0" Style="border: 1px solid var(--mud-palette-lines-default); display: inline-block;">
            <div style="display: inline-grid; grid-template-columns: repeat(@_level.GridWidth, @(TileSize)px); gap: 2px;">
                @for (var y = 0; y < _level.GridHeight; y++)
                {
                    @for (var x = 0; x < _level.GridWidth; x++)
                    {
                        var cx = x;
                        var cy = y;
                        var station = GetStationAt(cx, cy);
                        <div class="grid-tile @(station is not null ? "grid-tile-filled" : "")"
                             style="width: @(TileSize)px; height: @(TileSize)px;"
                             @onclick="() => OnTileClick(cx, cy)">
                            @if (station is not null)
                            {
                                <svg width="@(TileSize - 8)" height="@(TileSize - 8)" viewBox="0 0 20 20">
                                    @GetStationSvg(station.StationType)
                                </svg>
                            }
                        </div>
                    }
                }
            </div>
        </MudPaper>
    </div>
}

<style>
    .grid-tile {
        display: flex;
        align-items: center;
        justify-content: center;
        border-radius: 4px;
        cursor: pointer;
        transition: background-color 0.15s, transform 0.1s;
        background: var(--mud-palette-surface);
        border: 1px solid var(--mud-palette-lines-default);
    }
    .grid-tile:hover {
        background-color: color-mix(in srgb, var(--mud-palette-primary) 12%, transparent);
        transform: scale(1.05);
    }
    .grid-tile-filled {
        background: var(--mud-palette-background);
    }
    .grid-tile-filled:hover {
        opacity: 0.85;
    }
</style>

@code {
    [Parameter] public Guid LevelId { get; set; }

    private const int TileSize = 48;
    private const string StationColor = "#6366f1";
    private const string StationStroke = "#4338ca";

    private LevelDto? _level;
    private List<StationPlacement> _stations = [];
    private StationType _selectedType = StationType.Circle;
    private bool _eraseMode;

    private static readonly StationType[] _beginnerTypes = [StationType.Circle, StationType.Rectangle, StationType.Triangle];
    private static readonly StationType[] _advancedTypes = [StationType.Diamond, StationType.Cross, StationType.Ruby];

    protected override async Task OnInitializedAsync()
    {
        _level = await Mediator.Send(new GetLevelQuery(LevelId));
        if (_level is not null)
            _stations = _level.Stations.Select(s => new StationPlacement
            {
                GridX = s.GridX,
                GridY = s.GridY,
                StationType = s.StationType
            }).ToList();
    }

    private StationPlacement? GetStationAt(int x, int y) =>
        _stations.FirstOrDefault(s => s.GridX == x && s.GridY == y);

    private void SelectType(StationType type)
    {
        _selectedType = type;
        _eraseMode = false;
    }

    private void ToggleEraser()
    {
        _eraseMode = !_eraseMode;
    }

    private async Task OnTileClick(int x, int y)
    {
        if (_level is null) return;

        var existing = GetStationAt(x, y);

        if (_eraseMode)
        {
            if (existing is not null)
                _stations.Remove(existing);
        }
        else if (existing is not null && existing.StationType == _selectedType)
        {
            // Toggle off
            _stations.Remove(existing);
        }
        else
        {
            if (existing is not null)
                _stations.Remove(existing);

            _stations.Add(new StationPlacement
            {
                GridX = x,
                GridY = y,
                StationType = _selectedType
            });
        }

        // Persist to database
        await Mediator.Send(new UpdateGridDataCommand(LevelId, _stations));
    }

    private void GoBack() => Navigation.NavigateTo("/admin/levels");

    private static MarkupString GetStationSvg(StationType type) => type switch
    {
        StationType.Circle => new MarkupString($"""<circle cx="10" cy="10" r="7" fill="{StationColor}" stroke="{StationStroke}" stroke-width="1.5"/>"""),
        StationType.Rectangle => new MarkupString($"""<rect x="3" y="3" width="14" height="14" rx="2" fill="{StationColor}" stroke="{StationStroke}" stroke-width="1.5"/>"""),
        StationType.Triangle => new MarkupString($"""<polygon points="10,2 18,17 2,17" fill="{StationColor}" stroke="{StationStroke}" stroke-width="1.5"/>"""),
        StationType.Diamond => new MarkupString($"""<polygon points="10,1 19,10 10,19 1,10" fill="{StationColor}" stroke="{StationStroke}" stroke-width="1.5"/>"""),
        StationType.Cross => new MarkupString($"""<polygon points="7,2 13,2 13,7 18,7 18,13 13,13 13,18 7,18 7,13 2,13 2,7 7,7" fill="{StationColor}" stroke="{StationStroke}" stroke-width="1"/>"""),
        StationType.Ruby => new MarkupString($"""<polygon points="10,1 17,6 14,18 6,18 3,6" fill="{StationColor}" stroke="{StationStroke}" stroke-width="1.5"/>"""),
        _ => new MarkupString("")
    };
}
