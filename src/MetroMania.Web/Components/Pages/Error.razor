@page "/Error"
@using System.Diagnostics

<PageTitle>Error</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-8">
    <MudAlert Severity="Severity.Error">
        <MudText Typo="Typo.h5">Error</MudText>
        <MudText Typo="Typo.body1">An error occurred while processing your request.</MudText>
        @if (ShowRequestId)
        {
            <MudText Typo="Typo.caption" Class="mt-2">Request ID: @RequestId</MudText>
        }
    </MudAlert>
    <MudButton Href="/" Variant="Variant.Filled" Color="Color.Primary" Class="mt-4">Back to Home</MudButton>
</MudContainer>

@code{
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    private string? RequestId { get; set; }
    private bool ShowRequestId => !string.IsNullOrEmpty(RequestId);

    protected override void OnInitialized() =>
        RequestId = Activity.Current?.Id ?? HttpContext?.TraceIdentifier;
}
