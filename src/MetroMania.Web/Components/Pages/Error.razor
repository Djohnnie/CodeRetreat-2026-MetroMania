@page "/Error"
@using System.Diagnostics
@inject IStringLocalizer<Localization> Loc

<PageTitle>@Loc["Error"]</PageTitle>

<MudContainer MaxWidth="MaxWidth.Small" Class="mt-8">
    <MudAlert Severity="Severity.Error">
        <MudText Typo="Typo.h5">@Loc["Error"]</MudText>
        <MudText Typo="Typo.body1">@Loc["ErrorMessage"]</MudText>
        @if (ShowRequestId)
        {
            <MudText Typo="Typo.caption" Class="mt-2">@Loc["RequestId"]: @RequestId</MudText>
        }
    </MudAlert>
    <MudButton Href="/" Variant="Variant.Filled" Color="Color.Primary" Class="mt-4">@Loc["BackToHome"]</MudButton>
</MudContainer>

@code{
    [CascadingParameter]
    private HttpContext? HttpContext { get; set; }

    private string? RequestId { get; set; }
    private bool ShowRequestId => !string.IsNullOrEmpty(RequestId);

    protected override void OnInitialized() =>
        RequestId = Activity.Current?.Id ?? HttpContext?.TraceIdentifier;
}
