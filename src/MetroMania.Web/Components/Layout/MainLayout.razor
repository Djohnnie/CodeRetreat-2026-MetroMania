@inherits LayoutComponentBase
@using MetroMania.Web.Services
@using System.Security.Claims
@using System.Globalization
@inject AuthenticationStateProvider AuthStateProvider
@inject MetroManiaApiClient ApiClient
@inject NavigationManager Navigation
@inject IJSRuntime JSRuntime
@inject IStringLocalizer<Localization> Loc

<MudThemeProvider @ref="_themeProvider" Theme="_theme" IsDarkMode="_isDarkMode" />
<MudPopoverProvider />
<MudDialogProvider />
<MudSnackbarProvider />
<MudXProvider />

<CascadingValue Value="_isDarkMode" Name="IsDarkMode">

    <MudLayout>
        <MudAppBar Elevation="0" Dense="true" Class="appbar-blur">
            <MudIconButton Icon="@(_drawerOpen? Icons.Material.Filled.MenuOpen : Icons.Material.Filled.Menu)"
                           Color="Color.Inherit" Edge="Edge.Start"
                           OnClick="ToggleDrawer"
                           Class="hamburger-btn" />
            <a href="/" style="display: flex; align-items: center; text-decoration: none; color: inherit; cursor: pointer;">
                <MudIcon Icon="@Icons.Material.Filled.Train" Class="ml-2" />
                <MudText Typo="Typo.h6" Class="ml-2" Style="font-weight: 600; letter-spacing: 0.5px;">@Loc["AppName"]</MudText>
            </a>
            <MudSpacer />
            <AuthorizeView>
                <Authorized>
                    <MudMenu Icon="@Icons.Material.Filled.Language" Color="Color.Inherit" Dense="true"
                             AnchorOrigin="Origin.BottomCenter" TransformOrigin="Origin.TopCenter">
                        <MudMenuItem OnClick='() => ChangeLanguage("en")'>
                            🇬🇧 English
                        </MudMenuItem>
                        <MudMenuItem OnClick='() => ChangeLanguage("nl")'>
                            🇳🇱 Nederlands
                        </MudMenuItem>
                    </MudMenu>
                    <MudTooltip Text="@(_isDarkMode? Loc["SwitchToLight"] : Loc["SwitchToDark"])">
                        <MudIconButton Icon="@(_isDarkMode? Icons.Material.Filled.LightMode : Icons.Material.Filled.DarkMode)"
                                       Color="Color.Inherit" OnClick="ToggleTheme"
                                       Class="theme-toggle-btn" />
                    </MudTooltip>
                    <MudChip T="string" Size="Size.Small" Variant="Variant.Text" Color="Color.Default"
                             Class="mx-1" Icon="@Icons.Material.Filled.Person">
                        @context.User.Identity?.Name
                    </MudChip>
                    <MudTooltip Text="@Loc["Logout"]">
                        <MudIconButton Icon="@Icons.Material.Filled.Logout" Color="Color.Inherit" OnClick="LogoutAsync" />
                    </MudTooltip>
                    <MudTooltip Text="Conductor">
                        <MudIconButton Icon="@Icons.Material.Filled.SmartToy"
                                       Color="@(_conductorOpen ? Color.Primary : Color.Inherit)"
                                       Edge="Edge.End"
                                       OnClick="ToggleConductor"
                                       Class="conductor-btn" />
                    </MudTooltip>
                </Authorized>
                <NotAuthorized>
                    <MudMenu Icon="@Icons.Material.Filled.Language" Color="Color.Inherit" Dense="true"
                             AnchorOrigin="Origin.BottomCenter" TransformOrigin="Origin.TopCenter">
                        <MudMenuItem OnClick='() => ChangeLanguage("en")'>
                            🇬🇧 English
                        </MudMenuItem>
                        <MudMenuItem OnClick='() => ChangeLanguage("nl")'>
                            🇳🇱 Nederlands
                        </MudMenuItem>
                    </MudMenu>
                    <MudButton Href="/login" Color="Color.Inherit" Variant="Variant.Text">@Loc["Login"]</MudButton>
                    <MudButton Href="/register" Color="Color.Inherit" Variant="Variant.Text">@Loc["Register"]</MudButton>
                </NotAuthorized>
            </AuthorizeView>
        </MudAppBar>

        <MudDrawer @bind-Open="_drawerOpen" Elevation="0" ClipMode="DrawerClipMode.Always"
                   Class="drawer-animate" Variant="DrawerVariant.Responsive">
            <MudNavMenu Class="mt-2">
                <MudNavLink Href="/" Match="NavLinkMatch.All" Icon="@Icons.Material.Filled.Dashboard">
                    @Loc["Dashboard"]
                </MudNavLink>
                <AuthorizeView>
                    <Authorized>
                        <MudNavLink Href="/info" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.Info">
                            @Loc["GameInfo"]
                        </MudNavLink>
                        <MudNavLink Href="/leaderboard" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.EmojiEvents">
                            @Loc["Leaderboard"]
                        </MudNavLink>
                        <MudNavLink Href="/play" Match="NavLinkMatch.Prefix" Icon="@Icons.Material.Filled.SportsEsports">
                            @Loc["Play"]
                        </MudNavLink>
                    </Authorized>
                </AuthorizeView>
                <AuthorizeView Roles="Admin">
                    <Authorized>
                        <MudDivider />
                        <MudNavLink Href="/admin/levels" Icon="@Icons.Material.Filled.Layers">
                            @Loc["Levels"]
                        </MudNavLink>
                        <MudNavLink Href="/admin/submissions" Icon="@Icons.Material.Filled.History">
                            @Loc["Submissions"]
                        </MudNavLink>
                        <MudDivider />
                        <MudNavLink Href="/admin/users" Icon="@Icons.Material.Filled.People">
                            @Loc["UserManagement"]
                        </MudNavLink>
                    </Authorized>
                </AuthorizeView>
            </MudNavMenu>
        </MudDrawer>

        <MudDrawer @bind-Open="_conductorOpen"
                   Anchor="Anchor.Right"
                   Elevation="2"
                   Variant="DrawerVariant.Temporary"
                   Width="380px"
                   Class="conductor-drawer">
            <div class="conductor-drawer-inner">
                <div class="conductor-drawer-header">
                    <MudStack Row="true" AlignItems="AlignItems.Center" Class="pa-3">
                        <MudIcon Icon="@Icons.Material.Filled.SmartToy" />
                        <MudStack Spacing="0" Class="ml-2">
                            <MudText Typo="Typo.subtitle1" Style="font-weight: 700; line-height: 1.2;">Conductor</MudText>
                            <MudText Typo="Typo.caption" Color="Color.Success" Style="line-height: 1.2;">● Online</MudText>
                        </MudStack>
                        <MudSpacer />
                        <MudIconButton Icon="@Icons.Material.Filled.Close"
                                       Color="Color.Inherit"
                                       Size="Size.Small"
                                       OnClick="ToggleConductor" />
                    </MudStack>
                    <MudDivider />
                </div>

                <div class="conductor-messages">
                    @foreach (var msg in _conductorMessages)
                    {
                        <MudXChat ChatPosition="@(msg.IsUser ? ChatBubblePosition.End : ChatBubblePosition.Start)"
                                  Dense="true" Class="mb-2">
                            <MudXChatBubble>@((MarkupString)msg.Html)</MudXChatBubble>
                        </MudXChat>
                    }
                    @if (_conductorSending)
                    {
                        <MudXChat ChatPosition="ChatBubblePosition.Start" Dense="true" Class="mb-2">
                            <MudXChatBubble>
                                <MudProgressCircular Size="Size.Small" Indeterminate="true" />
                            </MudXChatBubble>
                        </MudXChat>
                    }
                    <div @ref="_conductorScrollAnchor"></div>
                </div>

                <div class="conductor-input">
                    <MudDivider />
                    <MudStack Row="true" AlignItems="AlignItems.Center" Spacing="1" Class="pa-2">
                        <MudTextField @bind-Value="_conductorMessage"
                                      Placeholder="Ask Conductor..."
                                      Variant="Variant.Outlined"
                                      Margin="Margin.Dense"
                                      Class="flex-grow-1"
                                      Immediate="true"
                                      Lines="1"
                                      Disabled="_conductorSending"
                                      OnKeyDown="OnConductorInputKeyDown" />
                        <MudIconButton Icon="@Icons.Material.Filled.Send"
                                       Color="Color.Primary"
                                       OnClick="SendConductorMessageAsync"
                                       Disabled="@(string.IsNullOrWhiteSpace(_conductorMessage) || _conductorSending)" />
                    </MudStack>
                </div>
            </div>
        </MudDrawer>

        <MudMainContent Class="pt-16 px-4">
            <MudContainer MaxWidth="MaxWidth.Large" Class="my-4 page-enter">
                @Body
            </MudContainer>
        </MudMainContent>
    </MudLayout>
</CascadingValue>

<div id="blazor-error-ui" data-nosnippet>
    An unhandled error has occurred.
    <a href="." class="reload">Reload</a>
    <span class="dismiss">🗙</span>
</div>

@code {
    private MudThemeProvider _themeProvider = null!;
    private bool _isDarkMode;
    private bool _drawerOpen = true;
    private bool _conductorOpen = false;
    private string _conductorMessage = string.Empty;
    private bool _conductorSending = false;
    private Guid _userId;
    private ElementReference _conductorScrollAnchor;
    private List<ConductorMessage> _conductorMessages = [];
    private string _currentLanguage = "en";

    private readonly MudTheme _theme = new()
    {
        PaletteLight = new PaletteLight
        {
            Primary = "#2563eb",
            Secondary = "#f59e0b",
            AppbarBackground = "rgba(255, 255, 255, 0.8)",
            AppbarText = "#1e293b",
            Background = "#f8fafc",
            Surface = "#ffffff",
            DrawerBackground = "#ffffff",
            DrawerText = "#334155",
            TableStriped = "#f1f5f9"
        },
        PaletteDark = new PaletteDark
        {
            Primary = "#60a5fa",
            Secondary = "#fbbf24",
            AppbarBackground = "rgba(15, 23, 42, 0.85)",
            AppbarText = "#e2e8f0",
            Background = "#0f172a",
            Surface = "#1e293b",
            DrawerBackground = "#1e293b",
            DrawerText = "#cbd5e1",
            TableStriped = "#1e293b"
        },
        Typography = new Typography
        {
            Default = new DefaultTypography
            {
                FontFamily = ["'Inter'", "'Roboto'", "'Helvetica'", "'Arial'", "sans-serif"]
            }
        },
        LayoutProperties = new LayoutProperties
        {
            DefaultBorderRadius = "12px"
        }
    };

    protected override async Task OnAfterRenderAsync(bool firstRender)
    {
        if (firstRender)
        {
            var authState = await AuthStateProvider.GetAuthenticationStateAsync();
            var user = authState.User;
            if (user.Identity?.IsAuthenticated == true)
            {
                if (Guid.TryParse(user.FindFirst(ClaimTypes.NameIdentifier)?.Value, out var uid))
                    _userId = uid;

                var darkClaim = user.FindFirst("IsDarkMode")?.Value;
                _isDarkMode = darkClaim == "True";

                // If user's stored language differs from the current request culture,
                // set the cookie and reload so the middleware applies the correct culture.
                var langClaim = user.FindFirst("Language")?.Value;
                if (!string.IsNullOrEmpty(langClaim))
                {
                    _currentLanguage = langClaim;
                    var currentCulture = CultureInfo.CurrentUICulture.TwoLetterISOLanguageName;
                    if (langClaim != currentCulture)
                    {
                        await SetCultureCookieAsync(langClaim);
                        Navigation.NavigateTo(Navigation.Uri, forceLoad: true);
                        return;
                    }
                }
            }
            else
            {
                _isDarkMode = false;
            }
            StateHasChanged();
        }
    }

    private void ToggleDrawer() => _drawerOpen = !_drawerOpen;

    private async Task ToggleConductor()
    {
        _conductorOpen = !_conductorOpen;
        if (_conductorOpen && _userId != Guid.Empty)
            await LoadChatHistoryAsync();
    }

    private async Task LoadChatHistoryAsync()
    {
        try
        {
            var history = await ApiClient.GetChatHistoryAsync(_userId);
            _conductorMessages = history
                .Select(m => new ConductorMessage(
                    m.Author == MetroMania.Domain.Enums.ChatMessageAuthor.User,
                    System.Web.HttpUtility.HtmlEncode(m.Content)))
                .ToList();
            StateHasChanged();
            await ScrollConductorToBottomAsync();
        }
        catch { /* ignore — keep current messages */ }
    }

    private async Task SendConductorMessageAsync()
    {
        var text = _conductorMessage.Trim();
        if (string.IsNullOrWhiteSpace(text) || _conductorSending) return;

        _conductorMessage = string.Empty;
        _conductorSending = true;
        _conductorMessages.Add(new(true, System.Web.HttpUtility.HtmlEncode(text)));
        StateHasChanged();
        await ScrollConductorToBottomAsync();

        try
        {
            var reply = await ApiClient.ChatWithConductorAsync(_userId, text);
            _conductorMessages.Add(new(false, System.Web.HttpUtility.HtmlEncode(reply)));
        }
        catch
        {
            _conductorMessages.Add(new(false, "⚠️ Sorry, I'm having trouble connecting right now. Please try again."));
        }
        finally
        {
            _conductorSending = false;
            StateHasChanged();
            await ScrollConductorToBottomAsync();
        }
    }

    private async Task OnConductorInputKeyDown(KeyboardEventArgs e)
    {
        if (e.Key == "Enter" && !e.ShiftKey)
            await SendConductorMessageAsync();
    }

    private async Task ScrollConductorToBottomAsync()
    {
        try
        {
            await JSRuntime.InvokeVoidAsync("eval",
                "document.querySelector('.conductor-messages')?.lastElementChild?.scrollIntoView({behavior:'smooth'})");
        }
        catch { /* ignore JS interop errors during prerender */ }
    }

    private async Task ToggleTheme()
    {
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var userIdStr = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
        if (Guid.TryParse(userIdStr, out var userId))
        {
            _isDarkMode = await ApiClient.ToggleThemeAsync(userId);
        }
    }

    private async Task ChangeLanguage(string language)
    {
        // Persist to DB if user is logged in
        var authState = await AuthStateProvider.GetAuthenticationStateAsync();
        var userIdStr = authState.User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
        if (Guid.TryParse(userIdStr, out var userId))
        {
            await ApiClient.ChangeLanguageAsync(userId, language);
        }

        // Set the culture cookie and reload — the middleware will apply the culture
        await SetCultureCookieAsync(language);
        Navigation.NavigateTo(Navigation.Uri, forceLoad: true);
    }

    private async Task SetCultureCookieAsync(string language)
    {
        var cookieValue = $"c={language}|uic={language}";
        await JSRuntime.InvokeVoidAsync("eval",
            $"document.cookie = '.AspNetCore.Culture={cookieValue};path=/;max-age=31536000;samesite=lax'");
    }

    private void LogoutAsync()
    {
        Navigation.NavigateTo("/api/auth/logout", forceLoad: true);
    }

    private sealed record ConductorMessage(bool IsUser, string Html);
}
